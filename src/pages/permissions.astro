---
import Layout from "../layouts/Layout.astro";
import DataTable from "../components/DataTable.astro";
import { db, PermissionDef, PermissionAssigned, User } from "astro:db";
import { parseTableQuery, buildTableResponse } from "../shared/table";
import { eq, like, desc, asc, sql, or } from "astro:db";
import { PERMISSION_SUBJECT_TYPES, PERMISSION_EFFECTS, PERMISSION_RESOURCE_TYPES } from "../shared/constants";

const { cookies, redirect, url } = Astro;

// Check authentication
const userId = cookies.get("user-id");
if (!userId) {
    return redirect("/login?error=Please login to access permissions");
}

// Get active tab from query params
const activeTab = url.searchParams.get("tab") || "definitions";

// Parse query parameters
const query = parseTableQuery(url);
const { page = 1, pageSize = 10, sortBy, sortOrder = 'asc', search } = query;
const offset = (page - 1) * pageSize;

// Fetch users for subject dropdown
const allUsers = await db.select().from(User);

// Handle Permission Definitions tab
let defs: any[] = [];
let defCount = 0;

if (activeTab === "definitions") {
    let defQuery: any = db.select().from(PermissionDef);
    let defCountQuery: any = db.select({ count: sql<number>`count(*)` }).from(PermissionDef);

    // Apply search for definitions
    if (search) {
        const searchCondition = or(
            like(PermissionDef.objectType, `%${search}%`),
            like(PermissionDef.resourceType, `%${search}%`),
            like(PermissionDef.resourceName, `%${search}%`),
            like(PermissionDef.description, `%${search}%`)
        );
        defQuery = defQuery.where(searchCondition);
        defCountQuery = defCountQuery.where(searchCondition);
    }

    // Apply sorting for definitions
    if (sortBy) {
        const orderFn = sortOrder === 'desc' ? desc : asc;
        if (sortBy === 'objectType') {
            defQuery = defQuery.orderBy(orderFn(PermissionDef.objectType));
        } else if (sortBy === 'resourceType') {
            defQuery = defQuery.orderBy(orderFn(PermissionDef.resourceType));
        } else if (sortBy === 'resourceName') {
            defQuery = defQuery.orderBy(orderFn(PermissionDef.resourceName));
        } else if (sortBy === 'id') {
            defQuery = defQuery.orderBy(orderFn(PermissionDef.id));
        } else {
            defQuery = defQuery.orderBy(desc(PermissionDef.id));
        }
    } else {
        defQuery = defQuery.orderBy(desc(PermissionDef.id));
    }

    defQuery = defQuery.limit(pageSize).offset(offset);

    const [defsResult, defCountResult] = await Promise.all([
        defQuery,
        defCountQuery,
    ]);
    defs = defsResult;
    defCount = defCountResult[0]?.count || 0;
}

// Handle Permission Assignments tab
let assignments: any[] = [];
let assignedCount = 0;

if (activeTab === "assignments") {
    let assignedQuery: any = db.select({
        id: PermissionAssigned.id,
        permissionDefId: PermissionAssigned.permissionDefId,
        subjectType: PermissionAssigned.subjectType,
        subjectId: PermissionAssigned.subjectId,
        effect: PermissionAssigned.effect,
        priority: PermissionAssigned.priority,
        status: PermissionAssigned.status,
        createdAt: PermissionAssigned.createdAt,
        updatedAt: PermissionAssigned.updatedAt,
        // Join with PermissionDef to get details
        objectType: PermissionDef.objectType,
        resourceType: PermissionDef.resourceType,
        resourceName: PermissionDef.resourceName,
        description: PermissionDef.description,
    }).from(PermissionAssigned)
        .leftJoin(PermissionDef, eq(PermissionAssigned.permissionDefId, PermissionDef.id)) as any;

    let assignedCountQuery: any = db.select({ count: sql<number>`count(*)` }).from(PermissionAssigned);

    // Apply search for assignments
    if (search) {
        const searchCondition = or(
            like(PermissionAssigned.subjectType, `%${search}%`),
            like(PermissionAssigned.effect, `%${search}%`)
        );
        assignedQuery = assignedQuery.where(searchCondition);
        assignedCountQuery = assignedCountQuery.where(searchCondition);
    }

    // Apply sorting for assignments
    if (sortBy) {
        const orderFn = sortOrder === 'desc' ? desc : asc;
        if (sortBy === 'subjectType') {
            assignedQuery = assignedQuery.orderBy(orderFn(PermissionAssigned.subjectType));
        } else if (sortBy === 'effect') {
            assignedQuery = assignedQuery.orderBy(orderFn(PermissionAssigned.effect));
        } else if (sortBy === 'priority') {
            assignedQuery = assignedQuery.orderBy(orderFn(PermissionAssigned.priority));
        } else if (sortBy === 'id') {
            assignedQuery = assignedQuery.orderBy(orderFn(PermissionAssigned.id));
        } else {
            assignedQuery = assignedQuery.orderBy(desc(PermissionAssigned.id));
        }
    } else {
        assignedQuery = assignedQuery.orderBy(desc(PermissionAssigned.id));
    }

    assignedQuery = assignedQuery.limit(pageSize).offset(offset);

    const [assignmentsResult, assignedCountResult] = await Promise.all([
        assignedQuery,
        assignedCountQuery,
    ]);
    assignments = assignmentsResult;
    assignedCount = assignedCountResult[0]?.count || 0;
}

// Build response based on active tab
let response;
if (activeTab === "definitions") {
    response = buildTableResponse(defs, defCount, query);
} else {
    response = buildTableResponse(assignments, assignedCount, query);
}

// Define columns for Permission Definitions
const defColumns = [
    {
        key: 'id',
        label: 'ID',
        sortable: true,
        className: 'font-mono text-xs',
    },
    {
        key: 'objectType',
        label: 'Object Type',
        sortable: true,
        filterable: true,
    },
    {
        key: 'resourceType',
        label: 'Resource Type',
        sortable: true,
        render: (value: any) => {
            const colors: Record<string, string> = {
                'ACTION': 'bg-blue-100 text-blue-800',
                'API': 'bg-green-100 text-green-800',
                'SCREEN': 'bg-purple-100 text-purple-800',
                'JOB': 'bg-orange-100 text-orange-800',
            };
            const bgColor = colors[value] || 'bg-gray-100 text-gray-800';
            return `<span class="px-2 py-1 rounded text-xs font-medium ${bgColor}">${value || 'N/A'}</span>`;
        },
    },
    {
        key: 'resourceName',
        label: 'Resource Name',
        sortable: true,
        filterable: true,
    },
    {
        key: 'description',
        label: 'Description',
        filterable: true,
    },
    {
        key: 'isActive',
        label: 'Active',
        render: (value: any) => {
            const isActive = value === true;
            const bgColor = isActive ? 'rgb(220 252 231)' : 'rgb(243 244 246)';
            const textColor = isActive ? 'rgb(22 101 52)' : 'rgb(31 41 55)';
            return `<span style="display: inline-block; padding: 0.25rem 0.5rem; border-radius: 9999px; font-size: 0.75rem; font-weight: 500; background-color: ${bgColor}; color: ${textColor};">${isActive ? 'Yes' : 'No'}</span>`;
        },
    },
    {
        key: 'createdAt',
        label: 'Created',
        sortable: true,
        render: (value: any) => {
            if (!value) return 'N/A';
            return new Date(value).toLocaleDateString();
        },
    },
];

// Define columns for Permission Assignments
const assignedColumns = [
    {
        key: 'id',
        label: 'ID',
        sortable: true,
        className: 'font-mono text-xs',
    },
    {
        key: 'objectType',
        label: 'Object Type',
        render: (value: any) => value || 'N/A',
    },
    {
        key: 'resourceType',
        label: 'Resource Type',
        render: (value: any) => {
            if (!value) return 'N/A';
            const colors: Record<string, string> = {
                'ACTION': 'bg-blue-100 text-blue-800',
                'API': 'bg-green-100 text-green-800',
                'SCREEN': 'bg-purple-100 text-purple-800',
                'JOB': 'bg-orange-100 text-orange-800',
            };
            const bgColor = colors[value] || 'bg-gray-100 text-gray-800';
            return `<span class="px-2 py-1 rounded text-xs font-medium ${bgColor}">${value}</span>`;
        },
    },
    {
        key: 'resourceName',
        label: 'Resource Name',
        render: (value: any) => value || 'N/A',
    },
    {
        key: 'subjectType',
        label: 'Subject Type',
        sortable: true,
        render: (value: any) => {
            const colors: Record<string, string> = {
                'USER': 'bg-indigo-100 text-indigo-800',
                'ROLE': 'bg-pink-100 text-pink-800',
                'GROUP': 'bg-yellow-100 text-yellow-800',
                'SYSTEM': 'bg-gray-100 text-gray-800',
            };
            const bgColor = colors[value] || 'bg-gray-100 text-gray-800';
            return `<span class="px-2 py-1 rounded text-xs font-medium ${bgColor}">${value || 'N/A'}</span>`;
        },
    },
    {
        key: 'subjectId',
        label: 'Subject ID',
        render: (value: any, row: any) => {
            if (!value) return 'All';
            if (row.subjectType === 'USER') {
                const user = allUsers.find(u => u.id === value);
                return user ? `${user.username} (${value})` : value;
            }
            return value;
        },
    },
    {
        key: 'effect',
        label: 'Effect',
        sortable: true,
        render: (value: any) => {
            const isAllow = value === PERMISSION_EFFECTS.ALLOW;
            const bgColor = isAllow ? 'rgb(220 252 231)' : 'rgb(254 226 226)';
            const textColor = isAllow ? 'rgb(22 101 52)' : 'rgb(153 27 27)';
            return `<span style="display: inline-block; padding: 0.25rem 0.5rem; border-radius: 9999px; font-size: 0.75rem; font-weight: 500; background-color: ${bgColor}; color: ${textColor};">${value || 'N/A'}</span>`;
        },
    },
    {
        key: 'priority',
        label: 'Priority',
        sortable: true,
        className: 'text-center',
    },
    {
        key: 'createdAt',
        label: 'Created',
        sortable: true,
        render: (value: any) => {
            if (!value) return 'N/A';
            return new Date(value).toLocaleDateString();
        },
    },
];

// Define actions for Permission Definitions
const defActions = [
    {
        label: 'Edit',
        action: 'edit',
        icon: '✏️',
        variant: 'secondary' as const,
        onClick: 'editPermissionDef',
    },
    {
        label: 'Delete',
        action: 'delete',
        icon: '🗑️',
        variant: 'danger' as const,
        onClick: 'deletePermissionDef',
    },
];

// Define actions for Permission Assignments
const assignedActions = [
    {
        label: 'Edit',
        action: 'edit',
        icon: '✏️',
        variant: 'secondary' as const,
        onClick: 'editPermissionAssigned',
    },
    {
        label: 'Delete',
        action: 'delete',
        icon: '🗑️',
        variant: 'danger' as const,
        onClick: 'deletePermissionAssigned',
    },
];
---

<Layout title="Permissions">
    <div class="max-w-7xl mx-auto py-6 sm:px-6 lg:px-8">
        <div class="px-4 py-6 sm:px-0">
            <!-- Tabs -->
            <div class="mb-6 border-b border-gray-200">
                <nav class="-mb-px flex space-x-8" aria-label="Tabs">
                    <a
                        href="/permissions?tab=definitions"
                        class={`whitespace-nowrap py-4 px-1 border-b-2 font-medium text-sm ${
                            activeTab === 'definitions'
                                ? 'border-indigo-500 text-indigo-600'
                                : 'border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300'
                        }`}
                    >
                        Permission Definitions
                    </a>
                    <a
                        href="/permissions?tab=assignments"
                        class={`whitespace-nowrap py-4 px-1 border-b-2 font-medium text-sm ${
                            activeTab === 'assignments'
                                ? 'border-indigo-500 text-indigo-600'
                                : 'border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300'
                        }`}
                    >
                        Permission Assignments
                    </a>
                </nav>
            </div>

            <!-- Add Button -->
            <div class="mb-6">
                <button
                    id={`add${activeTab === 'definitions' ? 'Def' : 'Assigned'}Btn`}
                    class="inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500"
                >
                    Add {activeTab === 'definitions' ? 'Permission Definition' : 'Permission Assignment'}
                </button>
            </div>

            <!-- Data Table -->
            {activeTab === 'definitions' ? (
                <DataTable
                    title="Permission Definitions"
                    description="Manage permission definitions (what permissions exist in the system)"
                    data={response.data}
                    columns={defColumns}
                    totalCount={response.totalCount}
                    currentPage={response.currentPage}
                    pageSize={response.pageSize}
                    sortBy={sortBy}
                    sortOrder={sortOrder}
                    searchQuery={search}
                    baseUrl={`/permissions?tab=definitions`}
                    actions={defActions}
                    showSearch={true}
                    showExport={true}
                    showColumnToggle={true}
                />
            ) : (
                <DataTable
                    title="Permission Assignments"
                    description="Manage permission assignments (who has what permissions)"
                    data={response.data}
                    columns={assignedColumns}
                    totalCount={response.totalCount}
                    currentPage={response.currentPage}
                    pageSize={response.pageSize}
                    sortBy={sortBy}
                    sortOrder={sortOrder}
                    searchQuery={search}
                    baseUrl={`/permissions?tab=assignments`}
                    actions={assignedActions}
                    showSearch={true}
                    showExport={true}
                    showColumnToggle={true}
                />
            )}
        </div>
    </div>
</Layout>

<script>
    function editPermissionDef(id: number) {
        console.log('Edit permission definition:', id);
        // TODO: Open edit modal or navigate to edit page
    }

    function deletePermissionDef(id: number) {
        if (confirm('Are you sure you want to delete this permission definition?')) {
            console.log('Delete permission definition:', id);
            fetch(`/api/permissions/definitions/${id}`, {
                method: 'DELETE',
            }).then(() => {
                window.location.reload();
            });
        }
    }

    function editPermissionAssigned(id: number) {
        console.log('Edit permission assignment:', id);
        // TODO: Open edit modal or navigate to edit page
    }

    function deletePermissionAssigned(id: number) {
        if (confirm('Are you sure you want to delete this permission assignment?')) {
            console.log('Delete permission assignment:', id);
            fetch(`/api/permissions/assignments/${id}`, {
                method: 'DELETE',
            }).then(() => {
                window.location.reload();
            });
        }
    }

    // Handle add buttons
    document.addEventListener('DOMContentLoaded', () => {
        const addDefBtn = document.getElementById('addDefBtn');
        const addAssignedBtn = document.getElementById('addAssignedBtn');
        
        if (addDefBtn) {
            addDefBtn.addEventListener('click', () => {
                // TODO: Open add modal for permission definition
                console.log('Add permission definition');
            });
        }
        
        if (addAssignedBtn) {
            addAssignedBtn.addEventListener('click', () => {
                // TODO: Open add modal for permission assignment
                console.log('Add permission assignment');
            });
        }
    });
</script>
