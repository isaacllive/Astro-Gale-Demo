---
import Layout from "../layouts/Layout.astro";
import DataTable from "../components/DataTable.astro";
import { db, PermissionDef, PermissionAssigned, User } from "astro:db";
import { parseTableQuery, buildTableResponse } from "../shared/table";
import { eq, like, desc, asc, sql, or } from "astro:db";
import { PERMISSION_SUBJECT_TYPES, PERMISSION_EFFECTS, PERMISSION_RESOURCE_TYPES } from "../shared/constants";

const { cookies, redirect, url } = Astro;

// Check authentication
const userId = cookies.get("user-id");
if (!userId) {
    return redirect("/login?error=Please login to access permissions");
}

// Get active tab from query params
const activeTab = url.searchParams.get("tab") || "definitions";

// Parse query parameters
const query = parseTableQuery(url);
const { page = 1, pageSize = 10, sortBy, sortOrder = 'asc', search } = query;
const offset = (page - 1) * pageSize;

// Fetch users for subject dropdown and all permission defs for assignment form
const [allUsers, allPermissionDefs] = await Promise.all([
    db.select().from(User),
    db.select({ id: PermissionDef.id, objectType: PermissionDef.objectType, resourceType: PermissionDef.resourceType, resourceName: PermissionDef.resourceName }).from(PermissionDef),
]);

// Handle Permission Definitions tab
let defs: any[] = [];
let defCount = 0;

if (activeTab === "definitions") {
    let defQuery: any = db.select().from(PermissionDef);
    let defCountQuery: any = db.select({ count: sql<number>`count(*)` }).from(PermissionDef);

    // Apply search for definitions
    if (search) {
        const searchCondition = or(
            like(PermissionDef.objectType, `%${search}%`),
            like(PermissionDef.resourceType, `%${search}%`),
            like(PermissionDef.resourceName, `%${search}%`),
            like(PermissionDef.description, `%${search}%`)
        );
        defQuery = defQuery.where(searchCondition);
        defCountQuery = defCountQuery.where(searchCondition);
    }

    // Apply sorting for definitions
    if (sortBy) {
        const orderFn = sortOrder === 'desc' ? desc : asc;
        if (sortBy === 'objectType') {
            defQuery = defQuery.orderBy(orderFn(PermissionDef.objectType));
        } else if (sortBy === 'resourceType') {
            defQuery = defQuery.orderBy(orderFn(PermissionDef.resourceType));
        } else if (sortBy === 'resourceName') {
            defQuery = defQuery.orderBy(orderFn(PermissionDef.resourceName));
        } else if (sortBy === 'id') {
            defQuery = defQuery.orderBy(orderFn(PermissionDef.id));
        } else {
            defQuery = defQuery.orderBy(desc(PermissionDef.id));
        }
    } else {
        defQuery = defQuery.orderBy(desc(PermissionDef.id));
    }

    defQuery = defQuery.limit(pageSize).offset(offset);

    const [defsResult, defCountResult] = await Promise.all([
        defQuery,
        defCountQuery,
    ]);
    defs = defsResult;
    defCount = defCountResult[0]?.count || 0;
}

// Handle Permission Assignments tab
let assignments: any[] = [];
let assignedCount = 0;

if (activeTab === "assignments") {
    let assignedQuery: any = db.select({
        id: PermissionAssigned.id,
        permissionDefId: PermissionAssigned.permissionDefId,
        subjectType: PermissionAssigned.subjectType,
        subjectId: PermissionAssigned.subjectId,
        effect: PermissionAssigned.effect,
        priority: PermissionAssigned.priority,
        status: PermissionAssigned.status,
        createdAt: PermissionAssigned.createdAt,
        updatedAt: PermissionAssigned.updatedAt,
        // Join with PermissionDef to get details
        objectType: PermissionDef.objectType,
        resourceType: PermissionDef.resourceType,
        resourceName: PermissionDef.resourceName,
        description: PermissionDef.description,
    }).from(PermissionAssigned)
        .leftJoin(PermissionDef, eq(PermissionAssigned.permissionDefId, PermissionDef.id)) as any;

    let assignedCountQuery: any = db.select({ count: sql<number>`count(*)` }).from(PermissionAssigned);

    // Apply search for assignments
    if (search) {
        const searchCondition = or(
            like(PermissionAssigned.subjectType, `%${search}%`),
            like(PermissionAssigned.effect, `%${search}%`)
        );
        assignedQuery = assignedQuery.where(searchCondition);
        assignedCountQuery = assignedCountQuery.where(searchCondition);
    }

    // Apply sorting for assignments
    if (sortBy) {
        const orderFn = sortOrder === 'desc' ? desc : asc;
        if (sortBy === 'subjectType') {
            assignedQuery = assignedQuery.orderBy(orderFn(PermissionAssigned.subjectType));
        } else if (sortBy === 'effect') {
            assignedQuery = assignedQuery.orderBy(orderFn(PermissionAssigned.effect));
        } else if (sortBy === 'priority') {
            assignedQuery = assignedQuery.orderBy(orderFn(PermissionAssigned.priority));
        } else if (sortBy === 'id') {
            assignedQuery = assignedQuery.orderBy(orderFn(PermissionAssigned.id));
        } else {
            assignedQuery = assignedQuery.orderBy(desc(PermissionAssigned.id));
        }
    } else {
        assignedQuery = assignedQuery.orderBy(desc(PermissionAssigned.id));
    }

    assignedQuery = assignedQuery.limit(pageSize).offset(offset);

    const [assignmentsResult, assignedCountResult] = await Promise.all([
        assignedQuery,
        assignedCountQuery,
    ]);
    assignments = assignmentsResult;
    assignedCount = assignedCountResult[0]?.count || 0;
}

// Build response based on active tab
let response;
if (activeTab === "definitions") {
    response = buildTableResponse(defs, defCount, query);
} else {
    response = buildTableResponse(assignments, assignedCount, query);
}

// Define columns for Permission Definitions
const defColumns = [
    {
        key: 'id',
        label: 'ID',
        sortable: true,
        className: 'font-mono text-xs',
    },
    {
        key: 'objectType',
        label: 'Object Type',
        sortable: true,
        filterable: true,
    },
    {
        key: 'resourceType',
        label: 'Resource Type',
        sortable: true,
        render: (value: any) => {
            const colors: Record<string, string> = {
                'ACTION': 'bg-blue-100 text-blue-800',
                'API': 'bg-green-100 text-green-800',
                'SCREEN': 'bg-purple-100 text-purple-800',
                'JOB': 'bg-orange-100 text-orange-800',
            };
            const bgColor = colors[value] || 'bg-gray-100 text-gray-800';
            return `<span class="px-2 py-1 rounded text-xs font-medium ${bgColor}">${value || 'N/A'}</span>`;
        },
    },
    {
        key: 'resourceName',
        label: 'Resource Name',
        sortable: true,
        filterable: true,
    },
    {
        key: 'description',
        label: 'Description',
        filterable: true,
    },
    {
        key: 'isActive',
        label: 'Active',
        render: (value: any) => {
            const isActive = value === true;
            const bgColor = isActive ? 'rgb(220 252 231)' : 'rgb(243 244 246)';
            const textColor = isActive ? 'rgb(22 101 52)' : 'rgb(31 41 55)';
            return `<span style="display: inline-block; padding: 0.25rem 0.5rem; border-radius: 9999px; font-size: 0.75rem; font-weight: 500; background-color: ${bgColor}; color: ${textColor};">${isActive ? 'Yes' : 'No'}</span>`;
        },
    },
    {
        key: 'createdAt',
        label: 'Created',
        sortable: true,
        render: (value: any) => {
            if (!value) return 'N/A';
            return new Date(value).toLocaleDateString();
        },
    },
];

// Define columns for Permission Assignments
const assignedColumns = [
    {
        key: 'id',
        label: 'ID',
        sortable: true,
        className: 'font-mono text-xs',
    },
    {
        key: 'objectType',
        label: 'Object Type',
        render: (value: any) => value || 'N/A',
    },
    {
        key: 'resourceType',
        label: 'Resource Type',
        render: (value: any) => {
            if (!value) return 'N/A';
            const colors: Record<string, string> = {
                'ACTION': 'bg-blue-100 text-blue-800',
                'API': 'bg-green-100 text-green-800',
                'SCREEN': 'bg-purple-100 text-purple-800',
                'JOB': 'bg-orange-100 text-orange-800',
            };
            const bgColor = colors[value] || 'bg-gray-100 text-gray-800';
            return `<span class="px-2 py-1 rounded text-xs font-medium ${bgColor}">${value}</span>`;
        },
    },
    {
        key: 'resourceName',
        label: 'Resource Name',
        render: (value: any) => value || 'N/A',
    },
    {
        key: 'subjectType',
        label: 'Subject Type',
        sortable: true,
        render: (value: any) => {
            const colors: Record<string, string> = {
                'USER': 'bg-primary-100 text-primary-800',
                'ROLE': 'bg-pink-100 text-pink-800',
                'GROUP': 'bg-yellow-100 text-yellow-800',
                'SYSTEM': 'bg-gray-100 text-gray-800',
            };
            const bgColor = colors[value] || 'bg-gray-100 text-gray-800';
            return `<span class="px-2 py-1 rounded text-xs font-medium ${bgColor}">${value || 'N/A'}</span>`;
        },
    },
    {
        key: 'subjectId',
        label: 'Subject ID',
        render: (value: any, row: any) => {
            if (!value) return 'All';
            if (row.subjectType === 'USER') {
                const user = allUsers.find(u => u.id === value);
                return user ? `${user.username} (${value})` : value;
            }
            return value;
        },
    },
    {
        key: 'effect',
        label: 'Effect',
        sortable: true,
        render: (value: any) => {
            const isAllow = value === PERMISSION_EFFECTS.ALLOW;
            const bgColor = isAllow ? 'rgb(220 252 231)' : 'rgb(254 226 226)';
            const textColor = isAllow ? 'rgb(22 101 52)' : 'rgb(153 27 27)';
            return `<span style="display: inline-block; padding: 0.25rem 0.5rem; border-radius: 9999px; font-size: 0.75rem; font-weight: 500; background-color: ${bgColor}; color: ${textColor};">${value || 'N/A'}</span>`;
        },
    },
    {
        key: 'priority',
        label: 'Priority',
        sortable: true,
        className: 'text-center',
    },
    {
        key: 'createdAt',
        label: 'Created',
        sortable: true,
        render: (value: any) => {
            if (!value) return 'N/A';
            return new Date(value).toLocaleDateString();
        },
    },
];

// Define actions for Permission Definitions
const defActions = [
    {
        label: 'Edit',
        action: 'edit',
        icon: '✏️',
        variant: 'secondary' as const,
        onClick: 'editPermissionDef',
    },
    {
        label: 'Delete',
        action: 'delete',
        icon: '🗑️',
        variant: 'danger' as const,
        onClick: 'deletePermissionDef',
    },
];

// Define actions for Permission Assignments
const assignedActions = [
    {
        label: 'Edit',
        action: 'edit',
        icon: '✏️',
        variant: 'secondary' as const,
        onClick: 'editPermissionAssigned',
    },
    {
        label: 'Delete',
        action: 'delete',
        icon: '🗑️',
        variant: 'danger' as const,
        onClick: 'deletePermissionAssigned',
    },
];
---

<Layout title="Permissions">
    <!-- Tabs -->
            <div class="mb-6 border-b border-gray-200">
                <nav class="-mb-px flex space-x-8" aria-label="Tabs">
                    <a
                        href="/permissions?tab=definitions"
                        class={`whitespace-nowrap py-4 px-1 border-b-2 font-medium text-sm ${
                            activeTab === 'definitions'
                                ? 'border-primary-500 text-primary-600'
                                : 'border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300'
                        }`}
                    >
                        Permission Definitions
                    </a>
                    <a
                        href="/permissions?tab=assignments"
                        class={`whitespace-nowrap py-4 px-1 border-b-2 font-medium text-sm ${
                            activeTab === 'assignments'
                                ? 'border-primary-500 text-primary-600'
                                : 'border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300'
                        }`}
                    >
                        Permission Assignments
                    </a>
                </nav>
            </div>

            <!-- Add Button -->
            <div class="mb-6">
                <button
                    id={`add${activeTab === 'definitions' ? 'Def' : 'Assigned'}Btn`}
                    class="inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-primary-600 hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary-500"
                >
                    Add {activeTab === 'definitions' ? 'Permission Definition' : 'Permission Assignment'}
                </button>
            </div>

            <!-- Data Table -->
            {activeTab === 'definitions' ? (
                <DataTable
                    title="Permission Definitions"
                    description="Manage permission definitions (what permissions exist in the system)"
                    data={response.data}
                    columns={defColumns}
                    totalCount={response.totalCount}
                    currentPage={response.currentPage}
                    pageSize={response.pageSize}
                    sortBy={sortBy}
                    sortOrder={sortOrder}
                    searchQuery={search}
                    baseUrl={`/permissions?tab=definitions`}
                    actions={defActions}
                    showSearch={true}
                    showExport={true}
                    showColumnToggle={true}
                    addNewOnClick="openAddDefModal"
                    addNewLabel="Add Permission Definition"
                />
            ) : (
                <DataTable
                    title="Permission Assignments"
                    description="Manage permission assignments (who has what permissions)"
                    data={response.data}
                    columns={assignedColumns}
                    totalCount={response.totalCount}
                    currentPage={response.currentPage}
                    pageSize={response.pageSize}
                    sortBy={sortBy}
                    sortOrder={sortOrder}
                    searchQuery={search}
                    baseUrl={`/permissions?tab=assignments`}
                    actions={assignedActions}
                    showSearch={true}
                    showExport={true}
                    showColumnToggle={true}
                    addNewOnClick="openAddAssignedModal"
                    addNewLabel="Add Permission Assignment"
                />
            )}

    <!-- Permission Definition Add/Edit Modal -->
    <div id="defModal" class="modal-overlay hidden" aria-hidden="true">
        <div class="modal-panel" role="dialog" aria-modal="true" aria-labelledby="defModalTitle">
            <h3 class="modal-title" id="defModalTitle">Edit Permission Definition</h3>
            <form id="defForm" class="space-y-4">
                <input type="hidden" id="defId" />
                <div>
                    <label for="defObjectType" class="form-label">Object Type</label>
                    <input type="text" id="defObjectType" name="objectType" required class="form-input" placeholder="e.g. USER, PERSON" />
                </div>
                <div>
                    <label for="defResourceType" class="form-label">Resource Type</label>
                    <select id="defResourceType" name="resourceType" required class="form-select">
                        <option value="">— Select —</option>
                        {Object.values(PERMISSION_RESOURCE_TYPES).map((t) => (
                            <option value={t}>{t}</option>
                        ))}
                    </select>
                </div>
                <div>
                    <label for="defResourceName" class="form-label">Resource Name</label>
                    <input type="text" id="defResourceName" name="resourceName" required class="form-input" placeholder="e.g. users:read" />
                </div>
                <div>
                    <label for="defDescription" class="form-label">Description</label>
                    <textarea id="defDescription" name="description" rows="2" class="form-input" placeholder="Optional"></textarea>
                </div>
                <div class="flex items-center gap-2">
                    <input type="checkbox" id="defIsActive" name="isActive" checked class="rounded border-gray-300" />
                    <label for="defIsActive" class="form-label mb-0">Active</label>
                </div>
                <div class="flex justify-end gap-3 pt-4">
                    <button type="button" id="defCancelBtn" class="btn-secondary">Cancel</button>
                    <button type="submit" class="btn-primary">Save</button>
                </div>
            </form>
        </div>
    </div>

    <!-- Permission Assignment Add/Edit Modal -->
    <div id="assignedModal" class="modal-overlay hidden" aria-hidden="true">
        <div class="modal-panel max-w-md" role="dialog" aria-modal="true" aria-labelledby="assignedModalTitle">
            <h3 class="modal-title" id="assignedModalTitle">Edit Permission Assignment</h3>
            <form id="assignedForm" class="space-y-4">
                <input type="hidden" id="assignedId" />
                <div>
                    <label for="assignedPermissionDefId" class="form-label">Permission</label>
                    <select id="assignedPermissionDefId" name="permissionDefId" required class="form-select">
                        <option value="">— Select —</option>
                        {allPermissionDefs.map((d) => (
                            <option value={d.id}>{d.resourceName} ({d.objectType} / {d.resourceType})</option>
                        ))}
                    </select>
                </div>
                <div>
                    <label for="assignedSubjectType" class="form-label">Subject Type</label>
                    <select id="assignedSubjectType" name="subjectType" required class="form-select">
                        {Object.values(PERMISSION_SUBJECT_TYPES).map((t) => (
                            <option value={t}>{t}</option>
                        ))}
                    </select>
                </div>
                <div>
                    <label for="assignedSubjectId" class="form-label">Subject ID (optional, for USER)</label>
                    <select id="assignedSubjectId" name="subjectId" class="form-select">
                        <option value="">— All / N/A —</option>
                        {allUsers.map((u) => (
                            <option value={u.id}>{u.username} (#{u.id})</option>
                        ))}
                    </select>
                </div>
                <div>
                    <label for="assignedEffect" class="form-label">Effect</label>
                    <select id="assignedEffect" name="effect" required class="form-select">
                        {Object.values(PERMISSION_EFFECTS).map((e) => (
                            <option value={e}>{e}</option>
                        ))}
                    </select>
                </div>
                <div>
                    <label for="assignedPriority" class="form-label">Priority</label>
                    <input type="number" id="assignedPriority" name="priority" value="0" min="0" class="form-input" />
                </div>
                <div class="flex justify-end gap-3 pt-4">
                    <button type="button" id="assignedCancelBtn" class="btn-secondary">Cancel</button>
                    <button type="submit" class="btn-primary">Save</button>
                </div>
            </form>
        </div>
    </div>
</Layout>

<script>
    import { actions } from 'astro:actions';
    import { navigate } from 'astro:transitions/client';

    const defModal = document.getElementById('defModal');
    const defForm = document.getElementById('defForm') as HTMLFormElement;
    const defModalTitle = document.getElementById('defModalTitle');
    const defIdInput = document.getElementById('defId') as HTMLInputElement;
    const defObjectTypeInput = document.getElementById('defObjectType') as HTMLInputElement;
    const defResourceTypeInput = document.getElementById('defResourceType') as HTMLSelectElement;
    const defResourceNameInput = document.getElementById('defResourceName') as HTMLInputElement;
    const defDescriptionInput = document.getElementById('defDescription') as HTMLTextAreaElement;
    const defIsActiveInput = document.getElementById('defIsActive') as HTMLInputElement;

    const assignedModal = document.getElementById('assignedModal');
    const assignedForm = document.getElementById('assignedForm') as HTMLFormElement;
    const assignedModalTitle = document.getElementById('assignedModalTitle');
    const assignedIdInput = document.getElementById('assignedId') as HTMLInputElement;
    const assignedPermissionDefIdInput = document.getElementById('assignedPermissionDefId') as HTMLSelectElement;
    const assignedSubjectTypeInput = document.getElementById('assignedSubjectType') as HTMLSelectElement;
    const assignedSubjectIdInput = document.getElementById('assignedSubjectId') as HTMLSelectElement;
    const assignedEffectInput = document.getElementById('assignedEffect') as HTMLSelectElement;
    const assignedPriorityInput = document.getElementById('assignedPriority') as HTMLInputElement;

    (window as any).openAddDefModal = () => {
        if (defModal && defModalTitle && defIdInput && defObjectTypeInput && defResourceTypeInput && defResourceNameInput && defDescriptionInput && defIsActiveInput) {
            defModalTitle.textContent = 'Add Permission Definition';
            defIdInput.value = '';
            defObjectTypeInput.value = '';
            defResourceTypeInput.value = '';
            defResourceNameInput.value = '';
            defDescriptionInput.value = '';
            defIsActiveInput.checked = true;
            defModal.classList.remove('hidden');
        }
    };

    (window as any).editPermissionDef = async (id: number) => {
        const { data, error } = await actions.getPermissionDef({ id });
        if (error || !data?.data || data.data.length === 0) {
            alert(error?.message || 'Failed to fetch permission definition');
            return;
        }
        const def = data.data[0];
        if (defModal && defModalTitle && defIdInput && defObjectTypeInput && defResourceTypeInput && defResourceNameInput && defDescriptionInput && defIsActiveInput) {
            defModalTitle.textContent = 'Edit Permission Definition';
            defIdInput.value = String(def.id);
            defObjectTypeInput.value = def.objectType || '';
            defResourceTypeInput.value = def.resourceType || '';
            defResourceNameInput.value = def.resourceName || '';
            defDescriptionInput.value = def.description || '';
            defIsActiveInput.checked = def.isActive !== false;
            defModal.classList.remove('hidden');
        }
    };

    async function deletePermissionDef(id: number) {
        if (confirm('Are you sure you want to delete this permission definition?')) {
            const result = await actions.deletePermissionDef({ id });
            if (result.data?.success) {
                navigate('/permissions?tab=definitions');
            } else {
                alert(result.error?.message || 'Failed to delete');
            }
        }
    }

    (window as any).openAddAssignedModal = () => {
        if (assignedModal && assignedModalTitle && assignedIdInput && assignedPermissionDefIdInput && assignedSubjectTypeInput && assignedSubjectIdInput && assignedEffectInput && assignedPriorityInput) {
            assignedModalTitle.textContent = 'Add Permission Assignment';
            assignedIdInput.value = '';
            assignedPermissionDefIdInput.value = '';
            assignedSubjectTypeInput.value = 'USER';
            assignedSubjectIdInput.value = '';
            assignedEffectInput.value = 'ALLOW';
            assignedPriorityInput.value = '0';
            assignedModal.classList.remove('hidden');
        }
    };

    (window as any).editPermissionAssigned = async (id: number) => {
        const { data, error } = await actions.getPermissionAssigned({ id });
        if (error || !data?.data || data.data.length === 0) {
            alert(error?.message || 'Failed to fetch permission assignment');
            return;
        }
        const a = data.data[0];
        if (assignedModal && assignedModalTitle && assignedIdInput && assignedPermissionDefIdInput && assignedSubjectTypeInput && assignedSubjectIdInput && assignedEffectInput && assignedPriorityInput) {
            assignedModalTitle.textContent = 'Edit Permission Assignment';
            assignedIdInput.value = String(a.id);
            assignedPermissionDefIdInput.value = String(a.permissionDefId);
            assignedSubjectTypeInput.value = a.subjectType || 'USER';
            assignedSubjectIdInput.value = a.subjectId != null ? String(a.subjectId) : '';
            assignedEffectInput.value = a.effect || 'ALLOW';
            assignedPriorityInput.value = String(a.priority ?? 0);
            assignedModal.classList.remove('hidden');
        }
    };

    async function deletePermissionAssigned(id: number) {
        if (confirm('Are you sure you want to delete this permission assignment?')) {
            const result = await actions.deletePermissionAssigned({ id });
            if (result.data?.success) {
                navigate('/permissions?tab=assignments');
            } else {
                alert(result.error?.message || 'Failed to delete');
            }
        }
    }

    document.getElementById('defCancelBtn')?.addEventListener('click', () => defModal?.classList.add('hidden'));
    document.getElementById('assignedCancelBtn')?.addEventListener('click', () => assignedModal?.classList.add('hidden'));

    defForm?.addEventListener('submit', async (e) => {
        e.preventDefault();
        const id = defIdInput?.value?.trim();
        const objectType = defObjectTypeInput?.value?.trim();
        const resourceType = defResourceTypeInput?.value;
        const resourceName = defResourceNameInput?.value?.trim();
        const description = defDescriptionInput?.value?.trim() || undefined;
        const isActive = defIsActiveInput?.checked ?? true;

        if (id) {
            const result = await actions.updatePermissionDef({
                id: Number(id),
                objectType,
                resourceType,
                resourceName,
                description,
                isActive,
            });
            if (result.data?.success) {
                defModal?.classList.add('hidden');
                navigate('/permissions?tab=definitions');
            } else {
                alert(result.error?.message || result.data?.message || 'Failed to update');
            }
        } else {
            const result = await actions.createPermissionDef({
                objectType: objectType || '',
                resourceType: resourceType || '',
                resourceName: resourceName || '',
                description,
                isActive,
            });
            if (result.data?.success) {
                defModal?.classList.add('hidden');
                navigate('/permissions?tab=definitions');
            } else {
                alert(result.error?.message || result.data?.message || 'Failed to create');
            }
        }
    });

    assignedForm?.addEventListener('submit', async (e) => {
        e.preventDefault();
        const id = assignedIdInput?.value?.trim();
        const permissionDefId = Number(assignedPermissionDefIdInput?.value);
        const subjectType = assignedSubjectTypeInput?.value;
        const subjectIdRaw = assignedSubjectIdInput?.value;
        const subjectId = subjectIdRaw === '' ? undefined : Number(subjectIdRaw);
        const effect = assignedEffectInput?.value;
        const priority = Number(assignedPriorityInput?.value || 0);

        if (id) {
            const result = await actions.updatePermissionAssigned({
                id: Number(id),
                permissionDefId,
                subjectType,
                subjectId: subjectId ?? null,
                effect,
                priority,
            });
            if (result.data?.success) {
                assignedModal?.classList.add('hidden');
                navigate('/permissions?tab=assignments');
            } else {
                alert(result.error?.message || result.data?.message || 'Failed to update');
            }
        } else {
            const result = await actions.createPermissionAssigned({
                permissionDefId,
                subjectType: subjectType || 'USER',
                subjectId: subjectId ?? null,
                effect: effect || 'ALLOW',
                priority,
            });
            if (result.data?.success) {
                assignedModal?.classList.add('hidden');
                navigate('/permissions?tab=assignments');
            } else {
                alert(result.error?.message || result.data?.message || 'Failed to create');
            }
        }
    });

    defModal?.addEventListener('click', (e) => { if (e.target === defModal) defModal.classList.add('hidden'); });
    assignedModal?.addEventListener('click', (e) => { if (e.target === assignedModal) assignedModal.classList.add('hidden'); });

    // Page Add buttons (above table)
    document.getElementById('addDefBtn')?.addEventListener('click', () => (window as any).openAddDefModal?.());
    document.getElementById('addAssignedBtn')?.addEventListener('click', () => (window as any).openAddAssignedModal?.());
</script>
