---
import Layout from "../layouts/Layout.astro";
import DataTable from "../components/DataTable.astro";
import { db, Person } from "astro:db";
import { parseTableQuery, buildTableResponse } from "../shared/table";
import { eq, like, desc, asc, sql, or } from "astro:db";

const { cookies, redirect, url } = Astro;

// Check authentication
const userId = cookies.get("user-id");
if (!userId) {
    return redirect("/login?error=Please login to access persons");
}

// Parse query parameters
const query = parseTableQuery(url);
const { page = 1, pageSize = 10, sortBy, sortOrder = "asc", search } = query;
const offset = (page - 1) * pageSize;

// Build query
let personQuery = db.select().from(Person);
let countQuery = db.select({ count: sql<number>`count(*)` }).from(Person);

// Apply search
if (search) {
    const searchCondition = or(
        like(Person.firstName, `%${search}%`),
        like(Person.lastName, `%${search}%`),
        like(Person.email, `%${search}%`),
        like(Person.phone, `%${search}%`),
    );
    personQuery = personQuery.where(searchCondition);
    countQuery = countQuery.where(searchCondition);
}

// Apply sorting
if (sortBy) {
    const orderFn = sortOrder === "desc" ? desc : asc;
    if (sortBy === "firstName") {
        personQuery = personQuery.orderBy(orderFn(Person.firstName));
    } else if (sortBy === "lastName") {
        personQuery = personQuery.orderBy(orderFn(Person.lastName));
    } else if (sortBy === "email") {
        personQuery = personQuery.orderBy(orderFn(Person.email));
    } else {
        personQuery = personQuery.orderBy(desc(Person.id));
    }
} else {
    personQuery = personQuery.orderBy(desc(Person.id));
}

// Apply pagination
personQuery = personQuery.limit(pageSize).offset(offset);

// Execute queries
const [persons, countResult] = await Promise.all([personQuery, countQuery]);

const totalCount = countResult[0]?.count || 0;
const response = buildTableResponse(persons, totalCount, query);

// Define columns
const columns = [
    {
        key: "id",
        label: "ID",
        sortable: true,
        className: "font-mono text-xs",
        width: "80px",
    },
    {
        key: "firstName",
        label: "First Name",
        sortable: true,
        filterable: true,
    },
    {
        key: "lastName",
        label: "Last Name",
        sortable: true,
        filterable: true,
    },
    {
        key: "email",
        label: "Email",
        sortable: true,
        filterable: true,
        render: (value: any) =>
            `<a href="mailto:${value}" style="color: rgb(99 102 241); text-decoration: none;" onmouseover="this.style.textDecoration='underline'" onmouseout="this.style.textDecoration='none'">${value}</a>`,
    },
    {
        key: "phone",
        label: "Phone",
        filterable: true,
    },
    {
        key: "city",
        label: "City",
        filterable: true,
    },
    {
        key: "state",
        label: "State",
        filterable: true,
    },
    {
        key: "gender",
        label: "Gender",
        render: (value: any) => {
            return value || "N/A";
        },
    },
    {
        key: "status",
        label: "Status",
        render: (value: any) => {
            const isActive = value === "active" || value === "Active";
            const bgColor = isActive ? "rgb(220 252 231)" : "rgb(243 244 246)";
            const textColor = isActive ? "rgb(22 101 52)" : "rgb(31 41 55)";
            return `<span style="display: inline-block; padding: 0.25rem 0.5rem; border-radius: 9999px; font-size: 0.75rem; font-weight: 500; background-color: ${bgColor}; color: ${textColor};">${value || "N/A"}</span>`;
        },
    },
];

// Define actions
const actions = [
    {
        label: "View",
        action: "view",
        icon: "👁️",
        variant: "secondary" as const,
        onClick: "viewPerson",
    },
    {
        label: "Edit",
        action: "edit",
        icon: "✏️",
        variant: "secondary" as const,
        onClick: "editPerson",
    },
    {
        label: "Delete",
        action: "delete",
        icon: "🗑️",
        variant: "danger" as const,
        onClick: "deletePerson",
    },
];
---

<Layout title="Persons">
    <DataTable
                title="Persons"
                description="Manage person records in the system"
                data={response.data}
                columns={columns}
                totalCount={response.totalCount}
                currentPage={response.currentPage}
                pageSize={response.pageSize}
                sortBy={sortBy}
                sortOrder={sortOrder}
                searchQuery={search}
                baseUrl="/persons"
                actions={actions}
                showSearch={true}
                showExport={true}
                showColumnToggle={true}
                addNewHref="/persons/new"
                addNewLabel="Add Person"
            />
</Layout>

<script>
    import { actions } from "astro:actions";
    import { navigate } from "astro:transitions/client";

    function viewPerson(id: number) {
        window.location.href = `/persons/${id}`;
    }

    function editPerson(id: number) {
        window.location.href = `/persons/${id}/edit`;
    }

    async function deletePerson(id: number) {
        if (confirm("Are you sure you want to delete this person?")) {
            const result = await actions.deletePerson({ id });
            if (result.data?.success) {
                navigate("/persons");
            } else {
                alert(result.error?.message || "Failed to delete person");
            }
        }
    }
</script>
