---
import Layout from "../layouts/Layout.astro";
---

<Layout title="About Us">
	<!-- Hero Section -->
	<section class="relative bg-white overflow-hidden">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 sm:py-24">
			<div class="text-center fade-in-up">
				<h1
					class="text-4xl tracking-tight font-extrabold text-gray-900 sm:text-5xl md:text-6xl"
				>
					<span class="block">About</span>{" "}
					<span class="block text-primary-600">Gale</span>
				</h1>
				<p
					class="mt-3 max-w-md mx-auto text-base text-gray-500 sm:text-lg md:mt-5 md:text-xl md:max-w-3xl"
				>
					We're building the future of business management, one
					innovation at a time.
				</p>
			</div>
		</div>
	</section>

	<!-- Mission & Vision Section -->
	<section class="py-16 bg-gray-50">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
			<div class="grid grid-cols-1 gap-8 lg:grid-cols-2">
				<!-- Mission -->
				<div class="bg-white rounded-lg shadow-sm p-8 fade-in-left">
					<div class="flex items-center mb-6">
						<div
							class="flex items-center justify-center h-12 w-12 rounded-md bg-primary-500 text-white"
						>
							<svg
								class="h-6 w-6"
								fill="none"
								stroke="currentColor"
								viewBox="0 0 24 24"
							>
								<path
									stroke-linecap="round"
									stroke-linejoin="round"
									stroke-width="2"
									d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"
								></path>
							</svg>
						</div>
						<h2 class="ml-4 text-2xl font-bold text-gray-900">
							Our Mission
						</h2>
					</div>
					<p class="text-gray-600 leading-relaxed">
						To empower businesses of all sizes with powerful,
						intuitive tools that streamline operations, enhance
						productivity, and drive growth. We believe that every
						organization deserves access to enterprise-grade
						solutions that are both accessible and affordable.
					</p>
				</div>

				<!-- Vision -->
				<div class="bg-white rounded-lg shadow-sm p-8 fade-in-right">
					<div class="flex items-center mb-6">
						<div
							class="flex items-center justify-center h-12 w-12 rounded-md bg-primary-500 text-white"
						>
							<svg
								class="h-6 w-6"
								fill="none"
								stroke="currentColor"
								viewBox="0 0 24 24"
							>
								<path
									stroke-linecap="round"
									stroke-linejoin="round"
									stroke-width="2"
									d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
								<path
									stroke-linecap="round"
									stroke-linejoin="round"
									stroke-width="2"
									d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"
								></path>
							</svg>
						</div>
						<h2 class="ml-4 text-2xl font-bold text-gray-900">
							Our Vision
						</h2>
					</div>
					<p class="text-gray-600 leading-relaxed">
						To become the leading platform for business management,
						recognized for our commitment to innovation, user
						experience, and customer success. We envision a world
						where managing a business is seamless, efficient, and
						enjoyable.
					</p>
				</div>
			</div>
		</div>
	</section>

	<!-- Values Section -->
	<section class="py-16 bg-white">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
			<div class="text-center mb-12">
				<h2
					class="text-base text-primary-600 font-semibold tracking-wide uppercase"
				>
					Our Values
				</h2>
				<p
					class="mt-2 text-3xl leading-8 font-extrabold tracking-tight text-gray-900 sm:text-4xl"
				>
					What drives us
				</p>
				<p class="mt-4 max-w-2xl text-xl text-gray-500 mx-auto">
					These core values guide everything we do and every decision
					we make.
				</p>
			</div>

			<div class="grid grid-cols-1 gap-8 sm:grid-cols-2 lg:grid-cols-4">
				<div class="text-center">
					<div
						class="mx-auto flex items-center justify-center h-16 w-16 rounded-md bg-primary-500 text-white"
					>
						<svg
							class="h-8 w-8"
							fill="none"
							stroke="currentColor"
							viewBox="0 0 24 24"
						>
							<path
								stroke-linecap="round"
								stroke-linejoin="round"
								stroke-width="2"
								d="M13 10V3L4 14h7v7l9-11h-7z"></path>
						</svg>
					</div>
					<h3 class="mt-6 text-lg font-medium text-gray-900">
						Innovation
					</h3>
					<p class="mt-2 text-base text-gray-500">
						We continuously push boundaries and embrace new
						technologies to deliver cutting-edge solutions.
					</p>
				</div>

				<div class="text-center">
					<div
						class="mx-auto flex items-center justify-center h-16 w-16 rounded-md bg-primary-500 text-white"
					>
						<svg
							class="h-8 w-8"
							fill="none"
							stroke="currentColor"
							viewBox="0 0 24 24"
						>
							<path
								stroke-linecap="round"
								stroke-linejoin="round"
								stroke-width="2"
								d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"
							></path>
						</svg>
					</div>
					<h3 class="mt-6 text-lg font-medium text-gray-900">
						Customer First
					</h3>
					<p class="mt-2 text-base text-gray-500">
						Our customers are at the heart of everything we do.
						Their success is our success.
					</p>
				</div>

				<div class="text-center">
					<div
						class="mx-auto flex items-center justify-center h-16 w-16 rounded-md bg-primary-500 text-white"
					>
						<svg
							class="h-8 w-8"
							fill="none"
							stroke="currentColor"
							viewBox="0 0 24 24"
						>
							<path
								stroke-linecap="round"
								stroke-linejoin="round"
								stroke-width="2"
								d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"
							></path>
						</svg>
					</div>
					<h3 class="mt-6 text-lg font-medium text-gray-900">
						Integrity
					</h3>
					<p class="mt-2 text-base text-gray-500">
						We operate with transparency, honesty, and ethical
						practices in all our interactions.
					</p>
				</div>

				<div class="text-center">
					<div
						class="mx-auto flex items-center justify-center h-16 w-16 rounded-md bg-primary-500 text-white"
					>
						<svg
							class="h-8 w-8"
							fill="none"
							stroke="currentColor"
							viewBox="0 0 24 24"
						>
							<path
								stroke-linecap="round"
								stroke-linejoin="round"
								stroke-width="2"
								d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"
							></path>
						</svg>
					</div>
					<h3 class="mt-6 text-lg font-medium text-gray-900">
						Collaboration
					</h3>
					<p class="mt-2 text-base text-gray-500">
						We believe in the power of teamwork and work together to
						achieve common goals.
					</p>
				</div>
			</div>
		</div>
	</section>

	<!-- Our Story Section -->
	<section class="py-16 bg-gray-50">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
			<div class="lg:grid lg:grid-cols-2 lg:gap-8">
				<div class="fade-in-left">
					<h2
						class="text-3xl font-extrabold text-gray-900 sm:text-4xl"
					>
						Our Story
					</h2>
					<p class="mt-3 text-lg text-gray-500">
						Gale was founded with a simple yet powerful vision: to
						make business management accessible to everyone. We
						recognized that many organizations, especially growing
						businesses, struggled with fragmented tools and
						overcomplicated systems.
					</p>
					<p class="mt-4 text-lg text-gray-500">
						Starting as a small team of passionate developers and
						business experts, we set out to create a platform that
						combines powerful functionality with intuitive design.
						Today, Gale serves businesses across various industries,
						helping them streamline operations and achieve their
						goals.
					</p>
					<p class="mt-4 text-lg text-gray-500">
						Our journey continues as we evolve our platform, listen
						to our customers, and adapt to the ever-changing needs
						of modern businesses. We're committed to being your
						trusted partner in growth.
					</p>
				</div>
				<div class="mt-10 lg:mt-0">
					<div class="space-y-10">
						<div class="relative">
							<div
								class="absolute flex items-center justify-center h-12 w-12 rounded-md bg-primary-500 text-white"
							>
								<span class="text-lg font-bold">1</span>
							</div>
							<div class="ml-16">
								<h3 class="text-lg font-medium text-gray-900">
									Founded
								</h3>
								<p class="mt-2 text-base text-gray-500">
									We started with a mission to simplify
									business management for everyone.
								</p>
							</div>
						</div>

						<div class="relative">
							<div
								class="absolute flex items-center justify-center h-12 w-12 rounded-md bg-primary-500 text-white"
							>
								<span class="text-lg font-bold">2</span>
							</div>
							<div class="ml-16">
								<h3 class="text-lg font-medium text-gray-900">
									Growth
								</h3>
								<p class="mt-2 text-base text-gray-500">
									Rapid expansion and continuous improvement
									based on user feedback.
								</p>
							</div>
						</div>

						<div class="relative">
							<div
								class="absolute flex items-center justify-center h-12 w-12 rounded-md bg-primary-500 text-white"
							>
								<span class="text-lg font-bold">3</span>
							</div>
							<div class="ml-16">
								<h3 class="text-lg font-medium text-gray-900">
									Today
								</h3>
								<p class="mt-2 text-base text-gray-500">
									Serving businesses worldwide with innovative
									solutions and unwavering support.
								</p>
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- Team Section -->
	<section class="py-16 bg-white">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
			<div class="text-center mb-12">
				<h2
					class="text-base text-primary-600 font-semibold tracking-wide uppercase"
				>
					Our Team
				</h2>
				<p
					class="mt-2 text-3xl leading-8 font-extrabold tracking-tight text-gray-900 sm:text-4xl"
				>
					Meet the people behind Gale
				</p>
				<p class="mt-4 max-w-2xl text-xl text-gray-500 mx-auto">
					We're a diverse group of talented individuals passionate
					about building great products.
				</p>
			</div>

			<div class="grid grid-cols-1 gap-8 sm:grid-cols-2 lg:grid-cols-3">
				<div class="text-center hover:scale-up">
					<div
						class="mx-auto h-24 w-24 rounded-full bg-primary-100 flex items-center justify-center"
					>
						<span class="text-3xl font-bold text-primary-600"
							>JD</span
						>
					</div>
					<h3 class="mt-6 text-lg font-medium text-gray-900">
						Jane Doe
					</h3>
					<p class="text-sm text-primary-600">
						Chief Executive Officer
					</p>
					<p class="mt-2 text-base text-gray-500">
						Leading our vision and strategy with over 15 years of
						experience in business technology.
					</p>
				</div>

				<div class="text-center hover:scale-up">
					<div
						class="mx-auto h-24 w-24 rounded-full bg-primary-100 flex items-center justify-center"
					>
						<span class="text-3xl font-bold text-primary-600"
							>JS</span
						>
					</div>
					<h3 class="mt-6 text-lg font-medium text-gray-900">
						John Smith
					</h3>
					<p class="text-sm text-primary-600">
						Chief Technology Officer
					</p>
					<p class="mt-2 text-base text-gray-500">
						Driving innovation and technical excellence across our
						platform and infrastructure.
					</p>
				</div>

				<div class="text-center hover:scale-up">
					<div
						class="mx-auto h-24 w-24 rounded-full bg-primary-100 flex items-center justify-center"
					>
						<span class="text-3xl font-bold text-primary-600"
							>SW</span
						>
					</div>
					<h3 class="mt-6 text-lg font-medium text-gray-900">
						Sarah Williams
					</h3>
					<p class="text-sm text-primary-600">Head of Product</p>
					<p class="mt-2 text-base text-gray-500">
						Ensuring our products meet customer needs and deliver
						exceptional user experiences.
					</p>
				</div>

				<div class="text-center hover:scale-up">
					<div
						class="mx-auto h-24 w-24 rounded-full bg-primary-100 flex items-center justify-center"
					>
						<span class="text-3xl font-bold text-primary-600"
							>MJ</span
						>
					</div>
					<h3 class="mt-6 text-lg font-medium text-gray-900">
						Michael Johnson
					</h3>
					<p class="text-sm text-primary-600">Head of Engineering</p>
					<p class="mt-2 text-base text-gray-500">
						Building scalable, reliable systems that power our
						platform's core functionality.
					</p>
				</div>

				<div class="text-center hover:scale-up">
					<div
						class="mx-auto h-24 w-24 rounded-full bg-primary-100 flex items-center justify-center"
					>
						<span class="text-3xl font-bold text-primary-600"
							>EB</span
						>
					</div>
					<h3 class="mt-6 text-lg font-medium text-gray-900">
						Emily Brown
					</h3>
					<p class="text-sm text-primary-600">Head of Design</p>
					<p class="mt-2 text-base text-gray-500">
						Creating beautiful, intuitive interfaces that make
						complex tasks feel simple.
					</p>
				</div>

				<div class="text-center hover:scale-up">
					<div
						class="mx-auto h-24 w-24 rounded-full bg-primary-100 flex items-center justify-center"
					>
						<span class="text-3xl font-bold text-primary-600"
							>DT</span
						>
					</div>
					<h3 class="mt-6 text-lg font-medium text-gray-900">
						David Taylor
					</h3>
					<p class="text-sm text-primary-600">
						Head of Customer Success
					</p>
					<p class="mt-2 text-base text-gray-500">
						Ensuring our customers achieve their goals and get
						maximum value from our platform.
					</p>
				</div>
			</div>
		</div>
	</section>

	<!-- CTA Section -->
	<section class="bg-primary-700">
		<div
			class="max-w-7xl mx-auto py-12 px-4 sm:px-6 lg:py-16 lg:px-8 lg:flex lg:items-center lg:justify-between"
		>
			<h2
				class="text-3xl font-extrabold tracking-tight text-white sm:text-4xl"
			>
				<span class="block">Ready to get started?</span>
				<span class="block text-primary-200"
					>Join us today and transform your business.</span
				>
			</h2>
			<div class="mt-8 flex lg:mt-0 lg:flex-shrink-0">
				<div class="inline-flex rounded-md shadow">
					<a
						href="/register"
						class="inline-flex items-center justify-center px-6 py-3 border border-transparent text-base font-medium rounded-md text-primary-600 bg-white hover:bg-primary-50"
					>
						Get started
					</a>
				</div>
				<div class="ml-3 inline-flex rounded-md shadow">
					<a
						href="/contact"
						class="inline-flex items-center justify-center px-6 py-3 border border-transparent text-base font-medium rounded-md text-white bg-primary-800 hover:bg-primary-900"
					>
						Contact us
					</a>
				</div>
			</div>
		</div>
	</section>
</Layout>

<style is:global>
	@keyframes fadeInUp {
		from {
			opacity: 0;
			transform: translateY(30px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	@keyframes fadeInLeft {
		from {
			opacity: 0;
			transform: translateX(-30px);
		}
		to {
			opacity: 1;
			transform: translateX(0);
		}
	}

	@keyframes fadeInRight {
		from {
			opacity: 0;
			transform: translateX(30px);
		}
		to {
			opacity: 1;
			transform: translateX(0);
		}
	}

	.fade-in-up {
		animation: fadeInUp 1s ease-out !important;
	}

	.fade-in-left {
		animation: fadeInLeft 1s ease-out !important;
	}

	.fade-in-right {
		animation: fadeInRight 1s ease-out !important;
	}
</style>
