---
import Layout from "../layouts/Layout.astro";

const faqs = [
	{
		question: "What is Gale?",
		answer: "Gale is a business management platform that helps organizations streamline operations, manage users and roles, track service requests, and stay on top of notifications. We combine powerful functionality with an intuitive interface.",
	},
	{
		question: "How do I reset my password?",
		answer: "If you've forgotten your password, use the \"Forgot password\" link on the login page. You'll receive an email with instructions to reset it. If you don't see the email, check your spam folder.",
	},
	{
		question: "How do I manage roles and permissions?",
		answer: "Logged-in users with the right permissions can go to the Roles page from the menu to create and edit roles. Assign roles to users from the Users page. Permissions control what each role can do within the application.",
	},
	{
		question: "What are service requests?",
		answer: "Service requests let you track and manage generic requests (e.g. support tickets, internal requests). You can create, assign, and update requests from the Service Requests page. Each request is linked to a person (requester) and can have a status and priority.",
	},
	{
		question: "Where can I see my notifications?",
		answer: "Click the bell icon in the header to see recent notifications, or go to the Notifications page for the full list. You can mark items as read and filter by type. Notifications can be success, warning, error, or info.",
	},
	{
		question: "How do I update my profile?",
		answer: "Go to Profile from the menu or your account dropdown. There you can update your name, username, and preferences such as dark mode. Changes are saved when you submit the form.",
	},
	{
		question: "Who do I contact for support?",
		answer: "Use the Contact page to get in touch with our team. For account or billing questions, include your email and we'll respond as soon as possible.",
	},
];
---

<Layout>
	<section class="bg-white dark:bg-gray-800 overflow-hidden">
		<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12 sm:py-16">
			<div class="text-center">
				<h1 class="text-4xl tracking-tight font-extrabold text-gray-900 dark:text-white sm:text-5xl">
					Frequently asked questions
				</h1>
				<p class="mt-3 max-w-2xl mx-auto text-base text-gray-500 dark:text-gray-400 sm:text-lg">
					Quick answers to common questions about Gale. Can't find what you need? <a href="/contact" class="text-primary-600 dark:text-primary-400 hover:underline">Contact us</a>.
				</p>
			</div>

			<div class="mt-12 space-y-3" x-data="{ openId: null }">
				{faqs.map((faq, i) => (
					<div
						class="rounded-lg border border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-800/50 overflow-hidden"
					>
						<button
							type="button"
							class="w-full flex items-center justify-between px-4 py-4 text-left text-sm font-medium text-gray-900 dark:text-white hover:bg-gray-100 dark:hover:bg-gray-700/50 transition-colors"
							@click="openId = openId === {i} ? null : {i}"
							:aria-expanded="openId === {i}"
						>
							<span>{faq.question}</span>
							<svg
								class="h-5 w-5 text-gray-500 dark:text-gray-400 flex-shrink-0 ml-2 transition-transform duration-200"
								:class="openId === {i} && 'rotate-180'"
								fill="none"
								stroke="currentColor"
								viewBox="0 0 24 24"
							>
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
							</svg>
						</button>
						<div
							x-show="openId === {i}"
							x-transition:enter="transition ease-out duration-200"
							x-transition:enter-start="opacity-0 -translate-y-2"
							x-transition:enter-end="opacity-100 translate-y-0"
							x-transition:leave="transition ease-in duration-150"
							x-transition:leave-start="opacity-100 translate-y-0"
							x-transition:leave-end="opacity-0 -translate-y-2"
							class="border-t border-gray-200 dark:border-gray-700"
							style="display: none;"
						>
							<div class="px-4 py-3 text-sm text-gray-600 dark:text-gray-300">
								{faq.answer}
							</div>
						</div>
					</div>
				))}
			</div>
		</div>
	</section>
</Layout>
