---
import Layout from "../layouts/Layout.astro";
import { db, eq, User } from "astro:db";

const { cookies, redirect } = Astro;

// Check authentication
const userIdCookie = cookies.get("user-id");
if (!userIdCookie) {
    return redirect("/login?error=Please login to access your profile");
}

const userId = parseInt(userIdCookie.value);

// Get user data
const users = await db.select().from(User).where(eq(User.id, userId));
if (users.length === 0) {
    return redirect("/login?error=User not found");
}

const user = users[0];
const darkModePreference = (user as { darkMode?: boolean }).darkMode ?? false;
---

<Layout title="Profile">
    <div class="max-w-4xl mx-auto">
        <!-- Page Header -->
        <div class="mb-6">
            <h1 class="page-title">Profile Settings</h1>
            <p class="page-description">Manage your account settings and preferences</p>
        </div>

        <!-- Profile Information Card -->
        <div class="card mb-6">
            <div class="card-header">
                <h2 class="card-header-title">Profile Information</h2>
            </div>
            <div class="card-body">
                <dl class="grid grid-cols-1 gap-6 sm:grid-cols-2">
                            <div>
                                <dt
                                    class="text-sm font-medium text-gray-500 dark:text-gray-400"
                                >
                                    Username
                                </dt>
                                <dd
                                    class="mt-1 text-sm text-gray-900 dark:text-gray-100"
                                    id="usernameDisplay"
                                >
                                    {user.username}
                                </dd>
                            </div>
                            <div>
                                <dt
                                    class="text-sm font-medium text-gray-500 dark:text-gray-400"
                                >
                                    Status
                                </dt>
                                <dd class="mt-1 text-sm">
                                    <span
                                        class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 dark:bg-green-900/30 text-green-800 dark:text-green-300"
                                    >
                                        {user.status || "Active"}
                                    </span>
                                </dd>
                            </div>
                            <div>
                                <dt
                                    class="text-sm font-medium text-gray-500 dark:text-gray-400"
                                >
                                    Account Created
                                </dt>
                                <dd
                                    class="mt-1 text-sm text-gray-900 dark:text-gray-100"
                                >
                                    {
                                        user.createdAt
                                            ? new Date(
                                                  user.createdAt,
                                              ).toLocaleDateString()
                                            : "N/A"
                                    }
                                </dd>
                            </div>
                            <div>
                                <dt
                                    class="text-sm font-medium text-gray-500 dark:text-gray-400"
                                >
                                    Last Login
                                </dt>
                                <dd
                                    class="mt-1 text-sm text-gray-900 dark:text-gray-100"
                                >
                                    {
                                        user.lastLogin
                                            ? new Date(
                                                  user.lastLogin,
                                              ).toLocaleDateString()
                                            : "Never"
                                    }
                                </dd>
                            </div>
                </dl>
            </div>
        </div>

        <!-- Preferences Card -->
        <div class="card mb-6">
            <div class="card-header">
                <h2 class="card-header-title">Preferences</h2>
            </div>
            <div class="card-body">
                        <div class="flex items-center justify-between">
                            <div>
                                <h3
                                    class="text-sm font-medium text-gray-900 dark:text-gray-100"
                                >
                                    Dark mode
                                </h3>
                                <p
                                    class="text-sm text-gray-500 dark:text-gray-400"
                                >
                                    Use dark theme across the application
                                </p>
                            </div>
                            <button
                                type="button"
                                id="darkModeToggle"
                                role="switch"
                                aria-checked={darkModePreference}
                                class="relative inline-flex h-6 w-11 flex-shrink-0 cursor-pointer rounded-full border-2 border-transparent transition-colors duration-200 ease-in-out focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 dark:focus:ring-offset-gray-800"
                                class:list={{
                                    "bg-primary-600": darkModePreference,
                                    "bg-gray-200 dark:bg-gray-600":
                                        !darkModePreference,
                                }}
                            >
                                <span
                                    aria-hidden="true"
                                    class="pointer-events-none inline-block h-5 w-5 transform rounded-full bg-white shadow ring-0 transition duration-200 ease-in-out"
                                    class:list={{
                                        "translate-x-5": darkModePreference,
                                        "translate-x-1": !darkModePreference,
                                    }}></span>
                            </button>
                        </div>
                    </div>
                </div>

        <!-- Edit Username Card -->
        <div class="card mb-6">
            <div class="card-header">
                <h2 class="card-header-title">Edit Username</h2>
            </div>
            <div class="card-body">
                        <form id="usernameForm" class="space-y-4">
                            <!-- Error Message -->
                            <div
                                id="usernameError"
                                class="hidden rounded-md bg-red-50 p-4"
                            >
                                <div class="flex">
                                    <div class="flex-shrink-0">
                                        <svg
                                            class="h-5 w-5 text-red-400"
                                            viewBox="0 0 20 20"
                                            fill="currentColor"
                                        >
                                            <path
                                                fill-rule="evenodd"
                                                d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z"
                                                clip-rule="evenodd"></path>
                                        </svg>
                                    </div>
                                    <div class="ml-3">
                                        <p
                                            id="usernameErrorText"
                                            class="text-sm font-medium text-red-800"
                                        >
                                        </p>
                                    </div>
                                </div>
                            </div>

                            <!-- Success Message -->
                            <div
                                id="usernameSuccess"
                                class="hidden rounded-md bg-green-50 p-4"
                            >
                                <div class="flex">
                                    <div class="flex-shrink-0">
                                        <svg
                                            class="h-5 w-5 text-green-400"
                                            viewBox="0 0 20 20"
                                            fill="currentColor"
                                        >
                                            <path
                                                fill-rule="evenodd"
                                                d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
                                                clip-rule="evenodd"></path>
                                        </svg>
                                    </div>
                                    <div class="ml-3">
                                        <p
                                            class="text-sm font-medium text-green-800"
                                        >
                                            Username updated successfully!
                                        </p>
                                    </div>
                                </div>
                            </div>

                            <div>
                                <label
                                    for="username"
                                    class="block text-sm font-medium text-gray-700"
                                >
                                    New Username
                                </label>
                                <input
                                    type="text"
                                    id="username"
                                    name="username"
                                    required
                                    minlength="3"
                                    value={user.username}
                                    class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-primary-500 focus:ring-primary-500 sm:text-sm px-3 py-2 border"
                                    placeholder="Enter new username"
                                />
                            </div>
                            <div>
                                <button
                                    type="submit"
                                    id="usernameSubmitBtn"
                                    class="inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-primary-600 hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary-500"
                                >
                                    Update Username
                                </button>
                            </div>
                        </form>
                    </div>
                </div>

                <!-- Change Password Card -->
                <div class="bg-white dark:bg-gray-800 shadow rounded-lg mb-6">
                    <div
                        class="px-6 py-4 border-b border-gray-200 dark:border-gray-700"
                    >
                        <h2
                            class="text-xl font-semibold text-gray-900 dark:text-gray-100"
                        >
                            Change Password
                        </h2>
                    </div>
                    <div class="px-6 py-4">
                        <form id="passwordForm" class="space-y-4">
                            <!-- Error Message -->
                            <div
                                id="passwordError"
                                class="hidden rounded-md bg-red-50 p-4"
                            >
                                <div class="flex">
                                    <div class="flex-shrink-0">
                                        <svg
                                            class="h-5 w-5 text-red-400"
                                            viewBox="0 0 20 20"
                                            fill="currentColor"
                                        >
                                            <path
                                                fill-rule="evenodd"
                                                d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z"
                                                clip-rule="evenodd"></path>
                                        </svg>
                                    </div>
                                    <div class="ml-3">
                                        <p
                                            id="passwordErrorText"
                                            class="text-sm font-medium text-red-800"
                                        >
                                        </p>
                                    </div>
                                </div>
                            </div>

                            <!-- Success Message -->
                            <div
                                id="passwordSuccess"
                                class="hidden rounded-md bg-green-50 p-4"
                            >
                                <div class="flex">
                                    <div class="flex-shrink-0">
                                        <svg
                                            class="h-5 w-5 text-green-400"
                                            viewBox="0 0 20 20"
                                            fill="currentColor"
                                        >
                                            <path
                                                fill-rule="evenodd"
                                                d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
                                                clip-rule="evenodd"></path>
                                        </svg>
                                    </div>
                                    <div class="ml-3">
                                        <p
                                            class="text-sm font-medium text-green-800"
                                        >
                                            Password changed successfully!
                                        </p>
                                    </div>
                                </div>
                            </div>

                            <div>
                                <label
                                    for="currentPassword"
                                    class="block text-sm font-medium text-gray-700"
                                >
                                    Current Password
                                </label>
                                <input
                                    type="password"
                                    id="currentPassword"
                                    name="currentPassword"
                                    required
                                    class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-primary-500 focus:ring-primary-500 sm:text-sm px-3 py-2 border"
                                    placeholder="Enter current password"
                                />
                            </div>
                            <div>
                                <label
                                    for="newPassword"
                                    class="block text-sm font-medium text-gray-700"
                                >
                                    New Password
                                </label>
                                <input
                                    type="password"
                                    id="newPassword"
                                    name="newPassword"
                                    required
                                    minlength="6"
                                    class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-primary-500 focus:ring-primary-500 sm:text-sm px-3 py-2 border"
                                    placeholder="Enter new password (min. 6 characters)"
                                />
                            </div>
                            <div>
                                <label
                                    for="confirmPassword"
                                    class="block text-sm font-medium text-gray-700"
                                >
                                    Confirm New Password
                                </label>
                                <input
                                    type="password"
                                    id="confirmPassword"
                                    name="confirmPassword"
                                    required
                                    minlength="6"
                                    class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-primary-500 focus:ring-primary-500 sm:text-sm px-3 py-2 border"
                                    placeholder="Confirm new password"
                                />
                            </div>
                            <div>
                                <button
                                    type="submit"
                                    id="passwordSubmitBtn"
                                    class="inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-primary-600 hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary-500"
                                >
                                    Change Password
                                </button>
                            </div>
                        </form>
                    </div>
                </div>

                <!-- Linked Person Information Card (if available) -->
                <div
                    id="personCard"
                    class="bg-white dark:bg-gray-800 shadow rounded-lg hidden"
                >
                    <div
                        class="px-6 py-4 border-b border-gray-200 dark:border-gray-700"
                    >
                        <h2
                            class="text-xl font-semibold text-gray-900 dark:text-gray-100"
                        >
                            Personal Information
                        </h2>
                    </div>
                    <div class="px-6 py-4">
                        <dl
                            class="grid grid-cols-1 gap-6 sm:grid-cols-2"
                            id="personInfo"
                        >
                            <!-- Person info will be populated by JavaScript -->
                        </dl>
                    </div>
                </div>
    </div>
</Layout>

<script define:vars={{ userId, darkModePreference }} lang="ts">
    import { actions } from "astro:actions";
    import { navigate } from "astro:transitions/client";
    const usernameForm = document.getElementById("usernameForm");
    const passwordForm = document.getElementById("passwordForm");
    const usernameError = document.getElementById("usernameError");
    const usernameErrorText = document.getElementById("usernameErrorText");
    const usernameSuccess = document.getElementById("usernameSuccess");
    const passwordError = document.getElementById("passwordError");
    const passwordErrorText = document.getElementById("passwordErrorText");
    const passwordSuccess = document.getElementById("passwordSuccess");
    const usernameDisplay = document.getElementById("usernameDisplay");
    const usernameSubmitBtn = document.getElementById("usernameSubmitBtn");
    const passwordSubmitBtn = document.getElementById("passwordSubmitBtn");

    // Load profile data including person info
    async function loadProfile() {
        try {
            const { data, error } = await actions.getProfile({ userId });
            if (error) {
                console.error("Error loading profile:", error);
                return;
            }

            if (data?.success && data.data) {
                // Sync dark mode from server
                if (typeof data.data.user.darkMode === "boolean") {
                    isDarkMode = data.data.user.darkMode;
                    updateDarkModeUI(document.getElementById("darkModeToggle"));
                }
                // Update username display if changed
                if (data.data.user.username && usernameDisplay) {
                    usernameDisplay.textContent = data.data.user.username;
                    const usernameInput = document.getElementById("username");
                    if (usernameInput instanceof HTMLInputElement) {
                        usernameInput.value = data.data.user.username;
                    }
                }

                // Display person information if available
                if (data.data.person) {
                    const personCard = document.getElementById("personCard");
                    const personInfo = document.getElementById("personInfo");
                    if (personCard && personInfo) {
                        const person = data.data.person;
                        personInfo.innerHTML = `
                            <div>
                                <dt class="text-sm font-medium text-gray-500">Full Name</dt>
                                <dd class="mt-1 text-sm text-gray-900">${person.firstName} ${person.lastName}</dd>
                            </div>
                            <div>
                                <dt class="text-sm font-medium text-gray-500">Email</dt>
                                <dd class="mt-1 text-sm text-gray-900">${person.email || "N/A"}</dd>
                            </div>
                            <div>
                                <dt class="text-sm font-medium text-gray-500">Phone</dt>
                                <dd class="mt-1 text-sm text-gray-900">${person.phone || "N/A"}</dd>
                            </div>
                            <div>
                                <dt class="text-sm font-medium text-gray-500">Gender</dt>
                                <dd class="mt-1 text-sm text-gray-900">${person.gender || "N/A"}</dd>
                            </div>
                            <div>
                                <dt class="text-sm font-medium text-gray-500">Date of Birth</dt>
                                <dd class="mt-1 text-sm text-gray-900">${person.dateOfBirth ? new Date(person.dateOfBirth).toLocaleDateString() : "N/A"}</dd>
                            </div>
                            <div>
                                <dt class="text-sm font-medium text-gray-500">Address</dt>
                                <dd class="mt-1 text-sm text-gray-900">${person.address || "N/A"}</dd>
                            </div>
                            <div>
                                <dt class="text-sm font-medium text-gray-500">City</dt>
                                <dd class="mt-1 text-sm text-gray-900">${person.city || "N/A"}</dd>
                            </div>
                            <div>
                                <dt class="text-sm font-medium text-gray-500">State</dt>
                                <dd class="mt-1 text-sm text-gray-900">${person.state || "N/A"}</dd>
                            </div>
                            <div>
                                <dt class="text-sm font-medium text-gray-500">Zip Code</dt>
                                <dd class="mt-1 text-sm text-gray-900">${person.zipCode || "N/A"}</dd>
                            </div>
                            <div>
                                <dt class="text-sm font-medium text-gray-500">Country</dt>
                                <dd class="mt-1 text-sm text-gray-900">${person.country || "N/A"}</dd>
                            </div>
                        `;
                        personCard.classList.remove("hidden");
                    }
                }
            }
        } catch (error) {
            console.error("Error loading profile:", error);
        }
    }

    // Handle username form submission
    usernameForm?.addEventListener("submit", async (e) => {
        e.preventDefault();
        e.stopPropagation();

        // Hide messages
        usernameError?.classList.add("hidden");
        usernameSuccess?.classList.add("hidden");

        // Disable submit button
        if (usernameSubmitBtn) {
            usernameSubmitBtn.disabled = true;
            usernameSubmitBtn.textContent = "Updating...";
        }

        if (!usernameForm || !(usernameForm instanceof HTMLFormElement)) return;
        const formData = new FormData(usernameForm);
        const username = String(formData.get("username") || "");

        if (!username || username.length < 3) {
            if (usernameError && usernameErrorText) {
                usernameErrorText.textContent =
                    "Username must be at least 3 characters long";
                usernameError.classList.remove("hidden");
            }
            if (usernameSubmitBtn) {
                usernameSubmitBtn.disabled = false;
                usernameSubmitBtn.textContent = "Update Username";
            }
            return;
        }

        try {
            const { data, error } = await actions.updateProfile({
                userId,
                username,
            });

            if (error) {
                if (usernameError && usernameErrorText) {
                    usernameErrorText.textContent =
                        error.message || "An error occurred";
                    usernameError.classList.remove("hidden");
                }
            } else if (data?.success) {
                usernameDisplay.textContent = username;
                usernameSuccess?.classList.remove("hidden");
                // Hide success message after 3 seconds
                setTimeout(() => {
                    usernameSuccess?.classList.add("hidden");
                }, 3000);
            } else {
                if (usernameError && usernameErrorText) {
                    usernameErrorText.textContent =
                        data?.error || "An error occurred";
                    usernameError.classList.remove("hidden");
                }
            }
        } catch (error) {
            if (usernameError && usernameErrorText) {
                usernameErrorText.textContent = "An unexpected error occurred";
                usernameError.classList.remove("hidden");
            }
        } finally {
            if (usernameSubmitBtn) {
                usernameSubmitBtn.disabled = false;
                usernameSubmitBtn.textContent = "Update Username";
            }
        }
    });

    // Handle password form submission
    passwordForm?.addEventListener("submit", async (e) => {
        e.preventDefault();
        e.stopPropagation();

        // Hide messages
        passwordError?.classList.add("hidden");
        passwordSuccess?.classList.add("hidden");

        if (!passwordForm || !(passwordForm instanceof HTMLFormElement)) return;
        const formData = new FormData(passwordForm);
        const currentPassword = String(formData.get("currentPassword") || "");
        const newPassword = String(formData.get("newPassword") || "");
        const confirmPassword = String(formData.get("confirmPassword") || "");

        // Validate passwords match
        if (newPassword !== confirmPassword) {
            if (passwordError && passwordErrorText) {
                passwordErrorText.textContent = "New passwords do not match";
                passwordError.classList.remove("hidden");
            }
            return;
        }

        if (newPassword.length < 6) {
            if (passwordError && passwordErrorText) {
                passwordErrorText.textContent =
                    "Password must be at least 6 characters long";
                passwordError.classList.remove("hidden");
            }
            return;
        }

        // Disable submit button
        if (passwordSubmitBtn) {
            passwordSubmitBtn.disabled = true;
            passwordSubmitBtn.textContent = "Changing...";
        }

        try {
            const { data, error } = await actions.changePassword({
                userId,
                currentPassword,
                newPassword,
            });

            if (error) {
                if (passwordError && passwordErrorText) {
                    passwordErrorText.textContent =
                        error.message || "An error occurred";
                    passwordError.classList.remove("hidden");
                }
            } else if (data?.success) {
                passwordSuccess?.classList.remove("hidden");
                // Clear form
                passwordForm.reset();
                // Hide success message after 3 seconds
                setTimeout(() => {
                    passwordSuccess?.classList.add("hidden");
                }, 3000);
            } else {
                if (passwordError && passwordErrorText) {
                    passwordErrorText.textContent =
                        data?.error || "An error occurred";
                    passwordError.classList.remove("hidden");
                }
            }
        } catch (error) {
            if (passwordError && passwordErrorText) {
                passwordErrorText.textContent = "An unexpected error occurred";
                passwordError.classList.remove("hidden");
            }
        } finally {
            if (passwordSubmitBtn) {
                passwordSubmitBtn.disabled = false;
                passwordSubmitBtn.textContent = "Change Password";
            }
        }
    });

    // Dark mode toggle — init on astro:page-load and DOMContentLoaded so the toggle exists (view transitions)
    let isDarkMode = darkModePreference;

    function updateDarkModeUI(toggleEl) {
        const thumb = toggleEl?.querySelector("span");
        if (toggleEl && thumb) {
            toggleEl.setAttribute("aria-checked", String(isDarkMode));
            toggleEl.classList.toggle("bg-primary-600", isDarkMode);
            toggleEl.classList.toggle("bg-gray-200", !isDarkMode);
            toggleEl.classList.toggle("dark:bg-gray-600", !isDarkMode);
            thumb.classList.toggle("translate-x-5", isDarkMode);
            thumb.classList.toggle("translate-x-1", !isDarkMode);
        }
        document.documentElement.classList.toggle("dark", isDarkMode);
    }

    function initDarkMode() {
        isDarkMode = darkModePreference;
        const darkModeToggle = document.getElementById("darkModeToggle");
        if (!darkModeToggle) return;
        updateDarkModeUI(darkModeToggle);

        if (darkModeToggle.dataset.darkModeInited) return;
        darkModeToggle.dataset.darkModeInited = "true";

        darkModeToggle.addEventListener("click", async () => {
            isDarkMode = !isDarkMode;
            updateDarkModeUI(darkModeToggle);
            document.cookie = `theme=${isDarkMode ? "dark" : "light"}; path=/; max-age=${60 * 60 * 24 * 365}; SameSite=Strict`;

            try {
                const { data, error } = await actions.updateProfile({
                    userId,
                    darkMode: isDarkMode,
                });
                if (error || !data?.success) {
                    isDarkMode = !isDarkMode;
                    updateDarkModeUI(darkModeToggle);
                    document.cookie = `theme=${isDarkMode ? "dark" : "light"}; path=/; max-age=${60 * 60 * 24 * 365}; SameSite=Strict`;
                }
            } catch {
                isDarkMode = !isDarkMode;
                updateDarkModeUI(darkModeToggle);
                document.cookie = `theme=${isDarkMode ? "dark" : "light"}; path=/; max-age=${60 * 60 * 24 * 365}; SameSite=Strict`;
            }
        });
    }

    document.addEventListener("astro:page-load", initDarkMode);
    if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", initDarkMode);
    } else {
        initDarkMode();
    }

    // Load profile on page load
    loadProfile();
</script>
