---
import type { ColumnDef, TableAction } from '../shared/table';

interface Props {
    title?: string;
    description?: string;
    data: any[];
    columns: ColumnDef[];
    totalCount: number;
    currentPage: number;
    pageSize: number;
    sortBy?: string;
    sortOrder?: 'asc' | 'desc';
    searchQuery?: string;
    baseUrl: string;
    actions?: TableAction[];
    showSearch?: boolean;
    showExport?: boolean;
    showColumnToggle?: boolean;
    /** Link for "Add new record" (e.g. /persons/new). Shown in table Actions dropdown. */
    addNewHref?: string;
    /** Label for add-new (default: "Add new record"). */
    addNewLabel?: string;
    /** Global function name to call for add (e.g. open modal). Used when add is not a link. */
    addNewOnClick?: string;
}

const {
    title,
    description,
    data = [],
    columns = [],
    totalCount = 0,
    currentPage = 1,
    pageSize = 10,
    sortBy,
    sortOrder = 'asc',
    searchQuery = '',
    baseUrl,
    actions = [],
    showSearch = true,
    showExport = true,
    showColumnToggle = true,
    addNewHref,
    addNewLabel = 'Add new record',
    addNewOnClick,
} = Astro.props;

const hasAddNew = Boolean(addNewHref || addNewOnClick);

const totalPages = Math.ceil(totalCount / pageSize);
const startRecord = (currentPage - 1) * pageSize + 1;
const endRecord = Math.min(currentPage * pageSize, totalCount);

// Build URL with query params
const buildUrl = (params: Record<string, any>) => {
    const url = new URL(baseUrl, 'http://localhost');
    Object.entries(params).forEach(([key, value]) => {
        if (value !== undefined && value !== null && value !== '') {
            url.searchParams.set(key, String(value));
        }
    });
    return url.search;
};

// Generate pagination page numbers with URLs
interface PaginationLink {
    pageNum: number;
    url: string;
    isActive: boolean;
}

const paginationLinks: PaginationLink[] = [];
const maxPages = Math.min(5, totalPages);
for (let i = 0; i < maxPages; i++) {
    let pageNum: number;
    if (totalPages <= 5) {
        pageNum = i + 1;
    } else if (currentPage <= 3) {
        pageNum = i + 1;
    } else if (currentPage >= totalPages - 2) {
        pageNum = totalPages - 4 + i;
    } else {
        pageNum = currentPage - 2 + i;
    }
    paginationLinks.push({
        pageNum,
        url: `${baseUrl}${buildUrl({
            page: pageNum,
            sortBy,
            sortOrder,
            search: searchQuery,
            pageSize,
        })}`,
        isActive: currentPage === pageNum,
    });
}
---

<div class="card data-table-container">
    <!-- Header -->
    <div class="flex flex-wrap justify-between items-start gap-4 px-6 py-4 border-b border-gray-200 dark:border-gray-700">
        <div>
            {title && <h2 class="text-xl font-bold text-gray-900 dark:text-gray-100">{title}</h2>}
            {description && <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">{description}</p>}
        </div>
        {(showExport || actions.length > 0 || hasAddNew) && (
        <div class="flex gap-2">
            <div class="relative" data-table-actions-wrap>
                <button
                    type="button"
                    class="btn-primary btn-sm inline-flex items-center gap-1.5"
                    onclick="toggleTableActionsMenu(event)"
                    aria-haspopup="true"
                    aria-expanded="false"
                    id="table-actions-trigger"
                >
                    <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6" />
                    </svg>
                    Actions
                    <svg class="h-4 w-4 opacity-70" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                    </svg>
                </button>
                <div id="table-actions-menu" class="actions-dropdown hidden" role="menu">
                    {hasAddNew && (
                        addNewHref ? (
                            <a href={addNewHref} class="actions-dropdown-item" role="menuitem" onclick="closeTableActionsMenu();">
                                <svg class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6" />
                                </svg>
                                {addNewLabel}
                            </a>
                        ) : (
                            <button type="button" class="actions-dropdown-item" role="menuitem" onclick={`typeof window.${addNewOnClick} === 'function' && window.${addNewOnClick}(); closeTableActionsMenu();`}>
                                <svg class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6" />
                                </svg>
                                {addNewLabel}
                            </button>
                        )
                    )}
                    {showExport && (
                        <button type="button" class="actions-dropdown-item" role="menuitem" onclick="exportTable(); closeTableActionsMenu();">
                            <svg class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                            </svg>
                            Export
                        </button>
                    )}
                    {actions.length > 0 && (
                        <button type="button" class="actions-dropdown-item" role="menuitem" onclick="handleBulkAction(); closeTableActionsMenu();">
                            <svg class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4" />
                            </svg>
                            Bulk actions
                        </button>
                    )}
                </div>
            </div>
        </div>
        )}
    </div>

    <!-- Toolbar -->
    <div class="flex flex-wrap justify-between items-center gap-4 px-4 py-3 border-b border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-800/50">
        {showSearch && (
            <div class="flex-1 min-w-0 max-w-md">
                <form method="GET" action={baseUrl} class="relative">
                    <input type="hidden" name="page" value="1" />
                    <input type="hidden" name="sortBy" value={sortBy || ''} />
                    <input type="hidden" name="sortOrder" value={sortOrder} />
                    <span class="pointer-events-none absolute left-3 top-1/2 -translate-y-1/2 text-gray-400 dark:text-gray-500" aria-hidden="true">
                        <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                        </svg>
                    </span>
                    <input
                        type="search"
                        name="search"
                        value={searchQuery}
                        placeholder="Search..."
                        class="form-input w-full pl-10 pr-10 py-2"
                    />
                    {searchQuery && (
                        <a href={baseUrl} class="absolute right-3 top-1/2 -translate-y-1/2 text-gray-400 hover:text-gray-600 dark:hover:text-gray-300" title="Clear search">
                            <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                            </svg>
                        </a>
                    )}
                </form>
            </div>
        )}

        <form method="GET" action={baseUrl} class="flex items-center gap-4">
            <input type="hidden" name="page" value="1" />
            <input type="hidden" name="sortBy" value={sortBy || ''} />
            <input type="hidden" name="sortOrder" value={sortOrder} />
            <input type="hidden" name="search" value={searchQuery || ''} />
            <label class="flex items-center gap-2 text-sm text-gray-600 dark:text-gray-400">
                Page size:
                <select
                    name="pageSize"
                    class="form-select py-1.5 px-2 w-auto text-sm"
                    onchange="this.form.submit()"
                >
                    <option value="10" selected={pageSize === 10}>10</option>
                    <option value="25" selected={pageSize === 25}>25</option>
                    <option value="50" selected={pageSize === 50}>50</option>
                    <option value="100" selected={pageSize === 100}>100</option>
                </select>
            </label>
        </form>
        {showColumnToggle && (
            <button type="button" class="btn-secondary btn-icon" onclick="toggleColumnMenu()" title="Toggle columns">
                <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
                </svg>
            </button>
        )}
        </div>
    </div>

    <!-- Table -->
    <div class="overflow-x-auto">
        <table class="data-table w-full min-w-full border-collapse">
            <thead>
                <tr class="bg-gray-50 dark:bg-gray-800/50">
                    <th class="data-table-th w-12 px-4 sm:px-6 py-3">
                        <input type="checkbox" class="rounded border-gray-300 dark:border-gray-600 text-primary-600 focus:ring-primary-500" onchange="toggleSelectAll(this)" />
                    </th>
                    {columns.map((column) => (
                        <th class={`data-table-th px-4 sm:px-6 py-3 ${column.className || ''}`} style={column.width ? `width: ${column.width}` : ''}>
                            <div class="flex items-center gap-2">
                                <span>{column.label}</span>
                                {column.sortable && (
                                    <a
                                        href={`${baseUrl}${buildUrl({
                                            page: 1,
                                            sortBy: column.key,
                                            sortOrder: sortBy === column.key && sortOrder === 'asc' ? 'desc' : 'asc',
                                            search: searchQuery,
                                            pageSize,
                                        })}`}
                                        class={`shrink-0 text-gray-400 hover:text-gray-600 dark:hover:text-gray-300 ${sortBy === column.key ? 'text-primary-600 dark:text-primary-400' : ''}`}
                                        title={`Sort by ${column.label}`}
                                    >
                                        <svg class={`h-4 w-4 ${sortBy === column.key && sortOrder === 'desc' ? 'rotate-180' : ''}`} fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16V4m0 0L3 8m4-4l4 4m6 0v12m0 0l4-4m-4 4l-4-4" />
                                        </svg>
                                    </a>
                                )}
                            </div>
                        </th>
                    ))}
                    {actions.length > 0 && <th class="data-table-th px-4 sm:px-6 py-3 w-24">Actions</th>}
                </tr>
            </thead>
            <tbody>
                {data.length === 0 ? (
                    <tr>
                        <td colspan={columns.length + (actions.length > 0 ? 2 : 1)} class="px-4 sm:px-6 py-12 text-center">
                            <div class="empty-state-container">
                                <svg class="empty-state-icon text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2-2v-5m16 0h-2.586a1 1 0 00-.707.293l-2.414 2.414a1 1 0 01-.707.293h-3.172a1 1 0 01-.707-.293l-2.414-2.414A1 1 0 006.586 13H4" />
                                </svg>
                                <p class="empty-state-title">No data found</p>
                            </div>
                        </td>
                    </tr>
                ) : (
                    data.map((row) => (
                        <tr data-id={row.id} class="data-table-tr border-b border-gray-200 dark:border-gray-700 last:border-0">
                            <td class="px-4 sm:px-6 py-3 w-12">
                                <input type="checkbox" class="row-checkbox rounded border-gray-300 dark:border-gray-600 text-primary-600 focus:ring-primary-500" value={row.id} />
                            </td>
                            {columns.map((column) => {
                                const cellValue = column.render
                                    ? column.render(row[column.key], row)
                                    : String(row[column.key] || '');
                                const isHtml = typeof cellValue === 'string' && (cellValue.includes('<') && cellValue.includes('>'));
                                if (isHtml) return <td class={`data-table-td ${column.className || ''}`} set:html={cellValue} />;
                                return <td class={`data-table-td ${column.className || ''}`}>{cellValue}</td>;
                            })}
                            {actions.length > 0 && (
                                <td class="px-4 sm:px-6 py-3 w-24">
                                    <div class="relative" data-row-actions-wrap>
                                        <button
                                            type="button"
                                            class="btn-secondary btn-sm inline-flex items-center gap-1"
                                            onclick={`toggleRowActionsMenu(event, ${row.id})`}
                                            aria-haspopup="true"
                                            aria-expanded="false"
                                            title="Actions"
                                        >
                                            Actions
                                            <svg class="h-3.5 w-3.5 opacity-70" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                                            </svg>
                                        </button>
                                        <div class="actions-dropdown row-actions-menu hidden" role="menu" data-row-id={row.id}>
                                            {actions.map((action) => (
                                                <button
                                                    type="button"
                                                    class={`actions-dropdown-item ${action.variant === 'danger' ? 'text-red-600 dark:text-red-400 hover:bg-red-50 dark:hover:bg-red-900/20' : ''}`}
                                                    role="menuitem"
                                                    onclick={action.onClick ? `${action.onClick}(${row.id}); closeRowActionsMenu(${row.id});` : `handleAction('${action.action}', ${row.id}); closeRowActionsMenu(${row.id});`}
                                                >
                                                    {action.icon && <span class="shrink-0">{action.icon}</span>}
                                                    {action.label}
                                                </button>
                                            ))}
                                        </div>
                                    </div>
                                </td>
                            )}
                        </tr>
                    ))
                )}
            </tbody>
        </table>
    </div>

    <!-- Pagination -->
    {totalPages > 1 && (
        <div class="flex flex-wrap justify-between items-center gap-4 px-4 py-3 border-t border-gray-200 dark:border-gray-700">
            <p class="text-sm text-gray-600 dark:text-gray-400">
                Showing {startRecord} to {endRecord} of {totalCount} entries
            </p>
            <div class="flex gap-1">
                <a
                    href={currentPage === 1 ? '#' : `${baseUrl}${buildUrl({ page: currentPage - 1, sortBy, sortOrder, search: searchQuery, pageSize })}`}
                    class={`pagination-btn ${currentPage === 1 ? 'opacity-50 pointer-events-none' : ''}`}
                    aria-label="Previous page"
                >
                    <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
                    </svg>
                </a>
                {paginationLinks.map((link) => (
                    <a href={link.url} class={`pagination-btn ${link.isActive ? 'pagination-btn-active' : ''}`}>
                        {link.pageNum}
                    </a>
                ))}
                <a
                    href={currentPage === totalPages ? '#' : `${baseUrl}${buildUrl({ page: currentPage + 1, sortBy, sortOrder, search: searchQuery, pageSize })}`}
                    class={`pagination-btn ${currentPage === totalPages ? 'opacity-50 pointer-events-none' : ''}`}
                    aria-label="Next page"
                >
                    <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                    </svg>
                </a>
            </div>
        </div>
    )}
</div>

<style>
    .actions-dropdown {
        position: absolute;
        top: 100%;
        right: 0;
        margin-top: 0.25rem;
        min-width: 10rem;
        padding: 0.25rem 0;
        background: var(--color-bg, #fff);
        border: 1px solid var(--color-border, #e5e7eb);
        border-radius: 0.375rem;
        box-shadow: 0 10px 15px -3px rgb(0 0 0 / 0.1), 0 4px 6px -4px rgb(0 0 0 / 0.1);
        z-index: 50;
    }
    .dark .actions-dropdown {
        background: var(--color-bg-dark);
        border-color: var(--color-border-dark, #374151);
    }
    .actions-dropdown.hidden {
        display: none;
    }
    .actions-dropdown:not(.hidden) {
        display: block;
    }
    .actions-dropdown-item {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        width: 100%;
        padding: 0.5rem 0.75rem;
        text-align: left;
        font-size: 0.875rem;
        color: var(--color-text, #374151);
        background: transparent;
        border: none;
        cursor: pointer;
    }
    .actions-dropdown-item:hover {
        background: var(--color-hover, #f3f4f6);
    }
    .dark .actions-dropdown-item {
        color: var(--color-text-dark, #e5e7eb);
    }
    .dark .actions-dropdown-item:hover {
        background: var(--color-hover-dark, #374151);
    }
    .row-actions-menu {
        left: 0;
        right: auto;
    }
    /* Responsive: smaller table and full-width toolbar on small screens */
    @media (max-width: 768px) {
        .data-table-container .data-table-td {
            white-space: normal;
            word-break: break-word;
        }
    }

    @media (max-width: 640px) {
        .data-table-container {
            border-radius: 0;
            margin-left: -1rem;
            margin-right: -1rem;
        }
    }
</style>

<script>
    function toggleSelectAll(checkbox: HTMLInputElement) {
        const checkboxes = document.querySelectorAll<HTMLInputElement>('.row-checkbox');
        checkboxes.forEach((cb) => {
            cb.checked = checkbox.checked;
        });
    }

    function exportTable() {
        // TODO: Implement export functionality
        console.log('Export table');
    }

    function handleBulkAction() {
        const selected = Array.from(
            document.querySelectorAll<HTMLInputElement>('.row-checkbox:checked')
        ).map((cb) => cb.value);
        console.log('Bulk action on:', selected);
    }

    function handleAction(action: string, id: number) {
        console.log('Action:', action, 'on ID:', id);
    }

    function toggleTableActionsMenu(ev: Event) {
        ev.stopPropagation();
        const menu = document.getElementById('table-actions-menu');
        const trigger = document.getElementById('table-actions-trigger');
        if (!menu || !trigger) return;
        const isOpen = !menu.classList.contains('hidden');
        closeAllActionsMenus();
        if (!isOpen) {
            menu.classList.remove('hidden');
            trigger.setAttribute('aria-expanded', 'true');
        } else {
            trigger.setAttribute('aria-expanded', 'false');
        }
    }

    function closeTableActionsMenu() {
        const menu = document.getElementById('table-actions-menu');
        const trigger = document.getElementById('table-actions-trigger');
        if (menu) menu.classList.add('hidden');
        if (trigger) trigger.setAttribute('aria-expanded', 'false');
    }

    function toggleRowActionsMenu(ev: Event, rowId: number) {
        ev.stopPropagation();
        const wrap = (ev.target as HTMLElement).closest('[data-row-actions-wrap]');
        const menu = wrap?.querySelector('.row-actions-menu');
        if (!menu) return;
        const isOpen = !menu.classList.contains('hidden');
        closeAllActionsMenus();
        if (!isOpen) {
            menu.classList.remove('hidden');
            (wrap?.querySelector('button[aria-haspopup]') as HTMLElement)?.setAttribute('aria-expanded', 'true');
        } else {
            (wrap?.querySelector('button[aria-haspopup]') as HTMLElement)?.setAttribute('aria-expanded', 'false');
        }
    }

    function closeRowActionsMenu(rowId: number) {
        const menu = document.querySelector(`.row-actions-menu[data-row-id="${rowId}"]`);
        const wrap = menu?.closest('[data-row-actions-wrap]');
        if (menu) menu.classList.add('hidden');
        (wrap?.querySelector('button[aria-haspopup]') as HTMLElement)?.setAttribute('aria-expanded', 'false');
    }

    function closeAllActionsMenus() {
        document.querySelectorAll('.actions-dropdown').forEach((el) => el.classList.add('hidden'));
        document.querySelectorAll('[data-table-actions-wrap] button[aria-haspopup], [data-row-actions-wrap] button[aria-haspopup]').forEach((el) => el.setAttribute('aria-expanded', 'false'));
    }

    document.addEventListener('click', () => closeAllActionsMenus());

    function toggleColumnMenu() {
        // TODO: Implement column toggle menu
        console.log('Toggle columns');
    }
</script>
