        const checkboxes = document.querySelectorAll<HTMLInputElement>('.row-checkbox');
        checkboxes.forEach((cb) => {
            cb.checked = checkbox.checked;
        });
    }

    function exportTable() {
        // TODO: Implement export functionality
        console.log('Export table');
