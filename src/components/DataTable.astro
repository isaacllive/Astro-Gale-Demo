    function handleBulkAction() {
        const selected = Array.from(
            document.querySelectorAll<HTMLInputElement>('.row-checkbox:checked')
        ).map((cb) => cb.value);
        console.log('Bulk action on:', selected);
    }

    function handleAction(action: string, id: number) {
        console.log('Action:', action, 'on ID:', id);
    }

    function toggleColumnMenu() {
        // TODO: Implement column toggle menu
        console.log('Toggle columns');
    }
</script>
