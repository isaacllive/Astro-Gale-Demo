---
interface Props {
	/** Optional: hide right sidebar (e.g. on small screens). Default true when logged in. */
	visible?: boolean;
}
const { visible = true } = Astro.props;
---
{visible && (
	<aside
		id="right-sidebar"
		class="right-sidebar right-sidebar-shell"
		aria-label="Right sidebar"
	>
		<div class="flex h-[calc(100vh-6rem)] flex-col overflow-hidden rounded-2xl">
			<div class="px-3 py-3 border-b border-gray-100 dark:border-gray-800/80">
				<h2 class="text-sm font-semibold tracking-tight text-gray-800 dark:text-gray-100">Details</h2>
			</div>
			<div class="flex-1 overflow-y-auto overflow-x-hidden px-2 py-3">
				<slot />
			</div>
		</div>
	</aside>
)}
