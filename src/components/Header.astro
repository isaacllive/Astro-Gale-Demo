---
import Logo from "./Logo.astro";

const { cookies } = Astro;
const { sidebarEnabled = false } = Astro.props;

const userIdCookie = cookies.get("user-id");
const isLoggedIn = !!userIdCookie?.value;
---

<header class="app-header w-full h-min">
    <div class="container mx-auto px-2 sm:px-3">
        <div class="flex items-center gap-4 h-16">
            <!-- Logo: always links to home - white island on primary header -->
            <div class="flex-shrink-0">
                <a
                    href="/"
                    class="flex items-center space-x-2 rounded-lg p-1.5 -ml-1 bg-white text-primary-700 hover:bg-primary-50 focus:outline-none focus:ring-2 focus:ring-primary-300"
                >
                    <div class="text-primary-600">
                        <Logo />
                    </div>
                    <span class="text-xl font-bold">Gale</span>
                </a>
            </div>
            <!-- Center: Search (when logged in) -->
            {isLoggedIn && (
                <div
                    class="flex-1 hidden md:flex justify-center min-w-0"
                    x-data="{ searchOpen: false }"
                    x-init="$watch('searchOpen', v => { if (v) $nextTick(() => $refs.searchInput?.focus()); })"
                    @keydown.escape.window="searchOpen = false"
                    @open-search.window="searchOpen = true"
                >
                    <div class="w-full max-w-xl">
                        <button
                            type="button"
                            @click="searchOpen = true"
                            class="w-full h-10 pl-4 pr-10 rounded-lg border border-primary-200 bg-white text-left text-primary-700 hover:bg-primary-50 hover:border-primary-300 focus:outline-none focus:ring-2 focus:ring-primary-300 focus:border-transparent text-sm flex items-center gap-3 shadow-sm"
                            aria-label="Open search"
                        >
                            <svg class="h-5 w-5 flex-shrink-0 text-primary-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
                            </svg>
                            <span>Search…</span>
                            <span class="ml-auto text-xs hidden sm:inline text-primary-500">⌘K</span>
                        </button>
                    </div>
                    <!-- Search modal -->
                    <div
                        x-show="searchOpen"
                        x-cloak
                        x-transition:enter="transition ease-out duration-200"
                        x-transition:enter-start="opacity-0"
                        x-transition:enter-end="opacity-100"
                        x-transition:leave="transition ease-in duration-150"
                        x-transition:leave-start="opacity-100"
                        x-transition:leave-end="opacity-0"
                        class="fixed inset-0 z-[100] flex items-start justify-center pt-[15vh] px-4"
                        style="display: none;"
                    >
                        <div
                            class="absolute inset-0 bg-white/80 dark:bg-gray-950/80 backdrop-blur-sm"
                            @click="searchOpen = false"
                            aria-hidden="true"
                        ></div>
                        <div
                            class="relative w-full max-w-xl rounded-xl shadow-2xl bg-white dark:bg-white border border-gray-200 dark:border-gray-300 overflow-hidden"
                            @click.stop
                        >
                            <form action="/search" method="get" role="search" class="flex items-center bg-white">
                                <label for="search-modal-input" class="sr-only">Search</label>
                                <span class="pl-4 text-gray-400" aria-hidden="true">
                                    <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
                                    </svg>
                                </span>
                                <input
                                    x-ref="searchInput"
                                    id="search-modal-input"
                                    type="search"
                                    name="q"
                                    placeholder="Search…"
                                    autocomplete="off"
                                    class="flex-1 h-14 pl-3 pr-4 bg-white text-gray-900 placeholder-gray-400 focus:outline-none text-base"
                                    aria-label="Search"
                                />
                                <button
                                    type="submit"
                                    class="mr-2 px-3 py-2 text-sm font-medium bg-primary-600 text-white hover:bg-primary-700 rounded-lg transition-colors"
                                >
                                    Search
                                </button>
                            </form>
                            <p class="px-4 pb-3 text-xs text-gray-500">
                                Press
                                <kbd class="px-1.5 py-0.5 rounded bg-gray-100 dark:bg-gray-800 font-mono text-[0.7rem]">Esc</kbd>
                                to close
                            </p>
                        </div>
                    </div>
                </div>
            )}
            <!-- Right: when logged in with sidebar, just a profile link (notifications/profile live in sidebar) -->
            <nav class="hidden md:flex flex-shrink-0 items-center ml-auto space-x-1">
                {isLoggedIn && (
                    <a
                        href="/contact"
                        class="text-white/90 hover:text-white hover:bg-primary-500/40 p-2 rounded-md inline-flex items-center transition-colors duration-200"
                        title="Assistance – Communicate with us"
                        aria-label="Assistance – Communicate with us"
                    >
                        <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"></path>
                        </svg>
                    </a>
                )}
                {isLoggedIn && sidebarEnabled && (
                    <a
                        href="/faq"
                        class="text-white/90 hover:text-white hover:bg-primary-500/40 p-2 rounded-md inline-flex items-center transition-colors duration-200"
                        title="FAQ"
                        aria-label="FAQ"
                    >
                        <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                        </svg>
                    </a>
                )}
                {!isLoggedIn && (
                    <a
                        href="/about"
                        class="text-white/90 hover:text-white hover:bg-primary-500/40 px-3 py-2 rounded-md text-sm font-medium"
                        >About</a
                    >
                )}
                {!isLoggedIn && (
                    <a
                        href="/faq"
                        class="text-white/90 hover:text-white hover:bg-primary-500/40 px-3 py-2 rounded-md text-sm font-medium"
                        >FAQ</a
                    >
                )}
                {!isLoggedIn && (
                    <a
                        href="/contact"
                        class="text-white/90 hover:text-white hover:bg-primary-500/40 px-3 py-2 rounded-md text-sm font-medium"
                        >Contact</a
                    >
                )}
                {!isLoggedIn && (
                    <!-- Auth Links -->
                    <div class="flex items-center space-x-4">
                        <a
                            href="/login"
                            class="text-white/90 hover:text-white hover:bg-primary-500/40 px-3 py-2 rounded-md text-sm font-medium"
                        >
                            Login
                        </a>
                        <a
                            href="/register"
                            class="bg-primary-600 text-white hover:bg-primary-700 px-4 py-2 rounded-md text-sm font-medium"
                        >
                            Sign up
                        </a>
                    </div>
                )}
            </nav>

            <!-- Mobile menu button - uses same sidebar toggle when sidebar enabled -->
            {!sidebarEnabled && (
                <div class="md:hidden">
                    <button
                        type="button"
                        class="inline-flex items-center justify-center p-2 rounded-md text-white/90 hover:text-white hover:bg-primary-500/40 focus:outline-none focus:ring-2 focus:ring-inset focus:ring-primary-200"
                    >
                        <span class="sr-only">Open main menu</span>
                        <svg class="block h-6 w-6" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
                        </svg>
                    </button>
                </div>
            )}
        </div>
    </div>
</header>

<script>
    import { actions } from "astro:actions";
    import { navigate } from "astro:transitions/client";

    let headerInited = false;
    function initHeader() {
        if (headerInited) return;
        headerInited = true;

        document.addEventListener("click", async (e) => {
            const btn = (e.target as Element).closest?.(".logout-btn");
            if (!btn) return;
            e.preventDefault();
            const { success } = await actions.logout.orThrow({
                success: false,
            });
            if (success) {
                navigate("/login");
            }
        });

        // Cmd+K / Ctrl+K to open search modal
        document.addEventListener("keydown", (e) => {
            if ((e.metaKey || e.ctrlKey) && e.key === "k") {
                e.preventDefault();
                document.dispatchEvent(new CustomEvent("open-search"));
            }
        });
    }

    document.addEventListener("astro:page-load", initHeader);
    if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", initHeader);
    } else {
        initHeader();
    }
</script>
